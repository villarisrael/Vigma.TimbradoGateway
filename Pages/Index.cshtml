@page
@model IndexModel
@{
    ViewData["Title"] = "Vigma Timbrado Gateway";
}

<link href="~/css/paginaprincipal.css" rel="stylesheet" />

<div class="container py-5">

    <!-- Hero Section -->
    <div class="hero-section p-4 p-md-5 mb-5 shadow-lg">
        <div class="row align-items-center g-5">
            <div class="col-lg-8">
                <span class="badge-modern mb-3">
                    <i class="bi bi-shield-check me-1"></i> Timbrado CFDI 4.0
                </span>

                <h1 class="display-5 fw-bold mb-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    Vigma Timbrado Gateway
                </h1>

                <p class="lead text-muted mb-4" style="font-size: 1.25rem;">
                    API centralizada para timbrado con MultiFacturas, multi-tenant, con gestión de certificados por cliente,
                    auditoría completa y panel de monitoreo en tiempo real.
                </p>

                <div class="d-flex flex-wrap gap-3">
                    <a class="btn btn-glow" href="/Monitor/Tenants">
                        <i class="bi bi-people-fill me-2"></i> Panel de Tenants
                    </a>

               
                    <a class="btn btn-outline-dark btn-lg px-4" href="/Errores" style="border-radius: 12px;">
                        <i class="bi bi-exclamation-triangle me-2"></i> Ver Errores
                    </a>

                    <a class="btn btn-outline-dark btn-lg px-4" href="/Timbrados" style="border-radius: 12px;">
                        <i class="bi bi-file-check me-2"></i> Ver Timbrados
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" asp-page-handler="Logout" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-lg px-4" style="border-radius: 12px;">
                                <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                            </button>
                        </form>
                    }
                </div>

                <div class="mt-4 d-flex align-items-center">
                    <span class="pulse online"></span>
                    <span class="status-indicator status-online ms-2">
                        Sistema Online • Última actualización: <span id="lastUpdate">hace 2 minutos</span>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="ms-3">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </span>
                        }
                    </span>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="rounded-4 border-0 p-4 shadow-sm" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                    <div class="card p-3">
                      <h5>Estado de servicios</h5>
                      <div id="mf">ApiRest de Mult: ...</div>
                      <div id="mine">Mi API: ...</div>
                       <div id="mdb">Mi DB: ...</div>
                      <small id="utc"></small>
                    </div>

                    <div class="small text-muted">
                        <div class="mb-2"><strong>⚡ Rendimiento:</strong> 95ms promedio por timbrado</div>
                        <div class="mb-2"><strong>🔒 Seguridad:</strong> Certificados TLS 1.3 activos</div>
                        <div class="mb-2"><strong>📊 Métricas:</strong> Actualización cada 60 segundos</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Métricas en Tiempo Real -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="metric-card success p-4 shadow">
                <div class="metric-icon" style="background: var(--success-gradient);">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="metric-value" id="activeTenants">0</div>
                <h6 class="text-muted mb-2">Tenants Activos</h6>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small text-success">
                        <i class="bi bi-arrow-up"></i> 0 nuevos este mes
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="metric-card dark p-4 shadow">
                <div class="metric-icon" style="background: var(--dark-gradient);">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div class="metric-value" id="stampedToday">0</div>
                <h6 class="text-muted mb-2">Timbrados Hoy</h6>
                <div class="small text-muted">Meta: 2,000 • 62% completado</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="metric-card warning p-4 shadow">
                <div class="metric-icon" style="background: var(--warning-gradient);">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="metric-value" id="avgTimbrados">0</div>
                <h6 class="text-muted mb-2">Promedio x hora</h6>
                <div class="small text-success">
                    <i class="bi bi-check-circle"></i> Dentro del SLA
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="metric-card danger p-4 shadow">
                <div class="metric-icon" style="background: var(--danger-gradient);">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div class="metric-value" id="errorRate">0.0</div>
                <h6 class="text-muted mb-2">% Error</h6>
                <div class="small text-danger" id="errores24">
                    12 errores en las últimas 24h
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de Uso (Placeholder) -->
    <div class="chart-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">Actividad de Timbrado - Últimas 24 horas</h5>
            <select class="form-select w-auto" style="border-radius: 10px;">
                <option>Últimas 24h</option>
                <option>Últimos 7 días</option>
                <option>Este mes</option>
            </select>
        </div>
        <div class="text-center py-5" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border-radius: 12px;">
            <i class="bi bi-bar-chart-fill display-1 text-muted mb-3"></i>
            <p class="text-muted">Gráfico de actividad se cargará aquí</p>
            <small class="text-muted">(Integrar con Chart.js o similar)</small>
        </div>
    </div>

</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<script>
    // Simulación de actualización de métricas en tiempo real
  
    // Efectos hover en tarjetas
    document.querySelectorAll('.metric-card, .feature-card').forEach(card => {
        card.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-5px)';
        });
        
        card.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
        });
    });
</script>

<script>
  async function revisar(){
    const r = await fetch("/api/health/all", { cache: "no-store" });
    const d = await r.json();

    // 1) Mi API
    document.getElementById("mine").textContent =
      (d.mine?.online ? "🟢" : "🔴") + " API VIGMA (HTTP " + (d.mine?.status ?? "-") + ")";

    // 2) MultiFacturas
    document.getElementById("mf").textContent =
      (d.multifacturas?.online ? "🟢" : "🔴") + " MultiFacturas " +
      (d.multifacturas?.online
        ? "(HTTP " + (d.multifacturas?.status ?? "-") + ")"
        : "(" + (d.multifacturas?.error ?? "sin detalle") + ")");

    // 3) Base de datos
    const db = d.database; // <-- aquí la "cachas"
    if (!db) {
      document.getElementById("mdb").textContent = "🟠 BD (sin datos)";
      return;
    }

    if (db.online) {
      document.getElementById("mdb").textContent =
        "🟢 BD MySQL (canConnect: " + db.canConnect + ")";
      
        document.getElementById("activeTenants").textContent = db.tenants ;
        document.getElementById("avgTimbrados").textContent = db.promedio ;
        document.getElementById("stampedToday").textContent = db.ultimos24 ;
         document.getElementById("errorRate").textContent = db.rateerrores ;

           document.getElementById("errores24").textContent = db.errores24 + " errores las ultimas 24 horas" ;

    } else {
      document.getElementById("mdb").textContent =
        "🔴 BD MySQL (" + (db.error ?? "error") + ")";
    }
  }

  revisar();
  setInterval(revisar, 30000);
</script>