@page
@model IndexModel
@{
    ViewData["Title"] = "Vigma Timbrado Gateway";
}
<link rel="stylesheet" href="~/css/paginaprincipal.css" asp-append-version="true" />
<link href="~/css/gstyle.css" rel="stylesheet" />

    <!-- Hero Section -->
<section class="hero-section">
    <div class="hero-content">

        <div class="hero-col-main">

                    <span class="badge-modern">
                        <i class="bi bi-shield-check"></i> Timbrado CFDI 4.0
                    </span>

            <h1 style="background: var(--vigma-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Vigma Timbrado Gateway
            </h1>

            <p class="hero-lead">
                API centralizada para timbrado con MultiFacturas, multi-tenant, con gestión de certificados
                por cliente, auditoría completa y panel de monitoreo en tiempo real.
            </p>

            <div class="hero-actions">
                <a class="vg-btn vg-btn-primary" href="/Monitor/Tenants">
                    <i class="bi bi-people-fill"></i> Panel de Tenants
                </a>
                <a class="vg-btn vg-btn-outline-wrong" href="/Errores">
                    <i class="bi bi-exclamation-triangle"></i> Ver Errores
                </a>
                <a class="vg-btn vg-btn-outline-timbre" href="/Timbrados">
                    <i class="bi bi-file-check"></i> Ver Timbrados
                </a>
            </div>

            <div class="services-status">
                <span class="status-indicator status-online">
                    <span class="pulse online"></span> Sistema Online
                </span>
                <small class="hero-last-update">
                    Última actualización: <span  id="lastUpdate">hace 2 minutos</span>
                </small>
            </div>

        </div>
        <!-- ↑ cierra hero-col-main -->

        <div class="hero-col-side">
            <div class="services-panel">
                <div class="services-card">

                    <h5>Estado de servicios</h5>
                    <div id="mf">ApiRest de Mult: ...</div>
                    <div id="mine">Mi API: ...</div>
                    <div id="mdb">Mi DB: ...</div>
                    <small id="utc"></small>

                    <table class="services-meta">
                        <tr>
                            <td><strong>Rendimiento</strong></td>
                            <td>95ms promedio por timbrado</td>
                        </tr>
                        <tr>
                            <td><strong>Seguridad</strong></td>
                            <td>Certificados TLS 1.3 activos</td>
                        </tr>
                        <tr>
                            <td><strong>Métricas</strong></td>
                            <td>Actualización cada 60 segundos</td>
                        </tr>
                    </table>

                </div>
                <!-- ↑ cierra services-card -->
            </div>
            <!-- ↑ cierra services-panel -->
        </div>
        <!-- ↑ cierra hero-col-side -->

    </div>
    <!-- ↑ cierra hero-content -->
</section>
<!-- ↑ cierra hero-section -->

    <!-- Métricas en Tiempo Real -->

<section class="metric-content">
    <div class="metrics-grid">

        <div class="metric-card success">
            <div class="metric-icon" style="background: var(--success-gradient);">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="metric-body">
                <div class="metric-value" style="color: var( --color-success) " id="activeTenants">0</div>
                <h6 class="metric-label">Tenants Activos</h6>
            </div>
            <span class="metric-footer metric-footer-success">
                <i class="bi bi-arrow-up"></i> 0 nuevos este mes
            </span>
        </div>

        <div class="metric-card dark">
            <div class="metric-icon" style="background: var(--dark-gradient);">
                <i class="bi bi-file-earmark-text"></i>
            </div>
            <div class="metric-body">
                <div class="metric-value" style="color:var(--color-dark)" id="stampedToday">0</div>
                <h6 class="metric-label">Timbrados Hoy</h6>
            </div>
            <span class="metric-footer">Meta: 2,000 • 62% completado</span>
        </div>

        <div class="metric-card throughput">
            <div class="metric-icon" style="background: var(--throughput-gradient);">
                <i class="bi bi-clock-history"></i>
            </div>
            <div class="metric-body">
                <div class="metric-value" style="color: var(--color-throughput)" id="avgTimbrados">0</div>
                <h6 class="metric-label">Promedio x hora</h6>
            </div>
            <span class="metric-footer metric-footer-success">
                <i class="bi bi-check-circle"></i> Dentro del SLA
            </span>
        </div>

        <div class="metric-card danger">
            <div class="metric-icon" style="background: var(--danger-gradient);">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="metric-body">
                <div class="metric-value" style="color: var(--color-danger)" id="errorRate">0.0</div>
                <h6 class="metric-label">% Error</h6>
            </div>
            <span class="metric-footer metric-footer-danger" id="errores24">
                12 errores en las últimas 24h
            </span>
        </div>

    </div>
</section>
<section class="chart-section">
    <div class="chart-header">
        <div class="chart-title-group">
            <h5 class="chart-title">Actividad de Timbrado</h5>
            <span class="chart-subtitle" id="chartSubtitle">Últimos 30 días</span>
        </div>
        <div class="chart-controls">
            <select class="chart-select" id="periodoSelector" onchange="cambiarPeriodo(this.value)">
                <option value="30" selected>Últimos 30 días</option>
                <option value="7">Últimos 7 días</option>
                <option value="15">Últimos 15 días</option>
                <option value="90">Últimos 90 días</option>
            </select>
            <button class="chart-refresh" onclick="refrescarDatos()" title="Actualizar datos">
                <i class="bi bi-arrow-repeat"></i>
            </button>
        </div>
    </div>

    <!-- Stats Cards del gráfico -->
    <div class="chart-stats" id="chartStats">
        <div class="stat-card-mini">
            <span class="stat-label">Total Timbrados</span>
            <span class="stat-value" id="totalTimbrados">0</span>
        </div>
        <div class="stat-card-mini">
            <span class="stat-label">Total Errores</span>
            <span class="stat-value" id="totalErrores">0</span>
        </div>
        <div class="stat-card-mini">
            <span class="stat-label">Promedio Diario</span>
            <span class="stat-value" id="promedioTimbrados">0</span>
        </div>
        <div class="stat-card-mini">
            <span class="stat-label">Tasa de Éxito</span>
            <span class="stat-value" id="tasaExito">0%</span>
        </div>
    </div>

    <!-- Leyenda del gráfico (se actualizará dinámicamente) -->
    <div class="chart-legend" id="chartLegend">
        <span class="legend-item legend-timbrados">
            <span class="legend-dot"></span> Timbrados
        </span>
        <span class="legend-item legend-errores">
            <span class="legend-dot"></span> Errores
        </span>
    </div>

    <!-- Contenedor del gráfico -->
    <div id="actividadChart" style="min-height: 350px; width: 100%;"></div>

    <!-- Loading overlay -->
    <div class="chart-loading" id="chartLoading" style="display: none;">
        <div class="spinner"></div>
        <span>Cargando datos...</span>
    </div>

    <!-- Error overlay -->
    <div class="chart-error" id="chartError" style="display: none;">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span id="errorMessage">Error al cargar los datos</span>
        <button onclick="refrescarDatos()" class="retry-btn">
            <i class="bi bi-arrow-repeat"></i>
            Reintentar
        </button>
    </div>
</section>
  



<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  
<script>
  // =========================
  // Configuración
  // =========================
  const API_BASE = '/api/Graficas';
  let chart = null;
  let periodoDias = 30;
  let currentTenantId = null;

  document.addEventListener('DOMContentLoaded', () => {
    // Asegura que Apex exista
    if (typeof ApexCharts === 'undefined') {
      console.error('ApexCharts no cargó. Revisa el script CDN o CSP.');
      mostrarError('No se pudo cargar ApexCharts (CDN).');
      return;
    }

    // Carga inicial
    cargarDatosGrafico();
  });

  // =========================
  // Acciones UI
  // =========================
  function cambiarPeriodo(value) {
    periodoDias = parseInt(value || '30', 10);
    const subtitle = document.getElementById('chartSubtitle');
    if (subtitle) subtitle.textContent = `Últimos ${periodoDias} días`;
    cargarDatosGrafico(currentTenantId);
  }

  function refrescarDatos() {
    cargarDatosGrafico(currentTenantId);
  }

  function filtrarPorTenant(tenantId) {
    currentTenantId = tenantId || null;
    cargarDatosGrafico(currentTenantId);
  }

  function exportarDatos() {
    window.location.href = `${API_BASE}/timbrados-vs-errores/exportar?days=${periodoDias}` + (currentTenantId ? `&tenantId=${currentTenantId}` : '');
  }

  // =========================
  // Carga de datos + render
  // =========================
  async function cargarDatosGrafico(tenantId = null) {
    try {
      mostrarLoading(true);
      ocultarError();

      let url = `${API_BASE}/timbrados-vs-errores?days=${periodoDias}`;
      if (tenantId) url += `&tenantId=${tenantId}`;

      const response = await fetch(url, { cache: 'no-store' });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const data = await response.json();

      // Normaliza arrays por si vienen como strings
      const fechas = Array.isArray(data.fechas) ? data.fechas : [];
      const timbrados = (Array.isArray(data.timbrados) ? data.timbrados : []).map(n => Number(n) || 0);
      const errores = (Array.isArray(data.errores) ? data.errores : []).map(n => Number(n) || 0);

      // Stats
      actualizarStats(data.resumen, timbrados, errores);

      // Render chart
      const options = getChartOptions({ fechas, timbrados, errores, resumen: data.resumen });

      if (chart) {
        chart.updateOptions(options, true, true);
      } else {
        chart = new ApexCharts(document.querySelector('#actividadChart'), options);
        await chart.render();
      }

    } catch (err) {
      console.error(err);
      mostrarError('No se pudieron cargar los datos del gráfico.');
      if (chart) {
        chart.destroy();
        chart = null;
      }
    } finally {
      mostrarLoading(false);
    }
  }

  // =========================
  // Opciones Apex
  // =========================
  function getChartOptions(data) {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    return {
      series: [
        { name: 'Timbrados', data: data.timbrados },
        { name: 'Errores', data: data.errores }
      ],
      chart: {
        type: 'area',
        height: 400,
        
        zoom: { enabled: true, type: 'x', autoScaleYaxis: true },
        background: 'transparent',
        parentHeightOffset: 0,
        animations: { enabled: true, easing: 'easeinout', speed: 800 }
      },
      colors: ['#0f9b8e', '#ff416c'],
      stroke: { curve: 'smooth', width: [2, 2], dashArray: [0, 3] },
      fill: {
        type: 'gradient',
        gradient: { shadeIntensity: 1, opacityFrom: 0.7, opacityTo: 0.2, stops: [0, 90, 100] }
      },
      dataLabels: { enabled: false },
      legend: {
        show: true,
        position: 'top',
        horizontalAlign: 'right',
        fontSize: '13px',
        markers: { width: 12, height: 12, radius: 6 },
        itemMargin: { horizontal: 10, vertical: 5 }
      },
      tooltip: {
        theme: isDark ? 'dark' : 'light',
        custom: function({ series, dataPointIndex, w }) {
          const timbrados = series[0][dataPointIndex] ?? 0;
          const errores = series[1][dataPointIndex] ?? 0;
          const fecha = w.globals.labels[dataPointIndex] ?? '';
          const porcentajeError = timbrados > 0 ? ((errores / timbrados) * 100).toFixed(2) : '0.00';

          // Tooltip “neutral” (no fuerzas blanco)
          return `
            <div class="custom-tooltip" style="padding:.75rem;border-radius:10px;box-shadow:0 8px 18px rgba(0,0,0,.12)">
              <div style="font-weight:700;margin-bottom:.5rem">${fecha}</div>
              <div style="display:flex;flex-direction:column;gap:.35rem">
                <div><span style="display:inline-block;width:8px;height:8px;background:#0f9b8e;border-radius:50%;margin-right:.5rem"></span>
                  Timbrados: <b style="color:#0f9b8e">${Number(timbrados).toLocaleString()}</b>
                </div>
                <div><span style="display:inline-block;width:8px;height:8px;background:#ff416c;border-radius:50%;margin-right:.5rem"></span>
                  Errores: <b style="color:#ff416c">${Number(errores).toLocaleString()}</b>
                </div>
                <div style="margin-top:.35rem;padding-top:.35rem;border-top:1px solid rgba(0,0,0,.08)">
                  Tasa de error: <b style="color:${Number(porcentajeError) > 5 ? '#ff416c' : '#0f9b8e'}">${porcentajeError}%</b>
                </div>
              </div>
            </div>
          `;
        }
      },
      xaxis: {
        categories: data.fechas,
        type: 'category',
        labels: {
          rotate: -45,
          hideOverlappingLabels: true,
          trim: true,
          style: { colors: isDark ? '#e2e8f0' : '#475569', fontSize: '11px' }
        },
        axisBorder: { show: false },
        axisTicks: { show: false },
        title: { text: `Últimos ${periodoDias} días`, style: { fontSize: '12px', color: isDark ? '#94a3b8' : '#64748b' } }
      },
      yaxis: {
        min: 0,
        labels: { style: { colors: isDark ? '#e2e8f0' : '#475569', fontSize: '11px' } },
        title: { text: 'Cantidad', style: { fontSize: '12px', color: isDark ? '#94a3b8' : '#64748b' } }
      },
      grid: {
        borderColor: isDark ? '#334155' : '#e2e8f0',
        strokeDashArray: 4
      },
      annotations: {
        yaxis: data.resumen?.promedioTimbrados ? [{
          y: Number(data.resumen.promedioTimbrados) || 0,
          borderColor: '#0f9b8e',
          label: { borderColor: '#0f9b8e', style: { color: '#fff', background: '#0f9b8e' }, text: 'Promedio timbrados' }
        }] : []
      },
      markers: {
        size: 4,
        strokeWidth: 2,
        hover: { size: 6 }
      },
      noData: {
        text: 'No hay datos disponibles',
        style: { color: isDark ? '#94a3b8' : '#64748b', fontSize: '14px' }
      }
    };
  }

  // =========================
  // Stats cards (los que YA tienes en tu HTML)
  // =========================
  function actualizarStats(resumen, timbradosArr, erroresArr) {
    // Si tu API ya trae "resumen", úsalo; si no, lo calculamos aquí
    const totalTimbrados = resumen?.totalTimbrados ?? timbradosArr.reduce((a,b)=>a+b,0);
    const totalErrores   = resumen?.totalErrores   ?? erroresArr.reduce((a,b)=>a+b,0);
    const promedio       = resumen?.promedioTimbrados ?? (timbradosArr.length ? Math.round(totalTimbrados / timbradosArr.length) : 0);

    const exito = totalTimbrados > 0
      ? (((totalTimbrados - totalErrores) / totalTimbrados) * 100).toFixed(2)
      : '0.00';

    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };

    set('totalTimbrados', Number(totalTimbrados).toLocaleString());
    set('totalErrores', Number(totalErrores).toLocaleString());
    set('promedioTimbrados', Number(promedio).toLocaleString());
    set('tasaExito', `${exito}%`);
  }

  // =========================
  // Overlays (usa tus divs #chartLoading y #chartError)
  // =========================
  function mostrarLoading(show) {
    const el = document.getElementById('chartLoading');
    if (el) el.style.display = show ? 'flex' : 'none';
  }

  function mostrarError(mensaje) {
    const box = document.getElementById('chartError');
    const msg = document.getElementById('errorMessage');
    if (msg) msg.textContent = mensaje || 'Error al cargar los datos';
    if (box) box.style.display = 'flex';
  }

  function ocultarError() {
    const box = document.getElementById('chartError');
    if (box) box.style.display = 'none';
  }

  // Auto-refresh cada 5 min
  setInterval(() => {
    if (!document.hidden) cargarDatosGrafico();
  }, 300000);
</script>




<script>
    // Simulación de actualización de métricas en tiempo real
  
    // Efectos hover en tarjetas
    document.querySelectorAll('.metric-card, .feature-card').forEach(card => {
        card.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-5px)';
        });
        
        card.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
        });
    });
</script>

<script>
    async function revisar(){
      const r = await fetch("/api/health/all", { cache: "no-store" });
      const d = await r.json();

      // 1) Mi API
      document.getElementById("mine").textContent =
        (d.mine?.online ? "🟢" : "🔴") + " API VIGMA (HTTP " + (d.mine?.status ?? "-") + ")";

      // 2) MultiFacturas
      document.getElementById("mf").textContent =
        (d.multifacturas?.online ? "🟢" : "🔴") + " MultiFacturas " +
        (d.multifacturas?.online
          ? "(HTTP " + (d.multifacturas?.status ?? "-") + ")"
          : "(" + (d.multifacturas?.error ?? "sin detalle") + ")");

      // 3) Base de datos
      const db = d.database; // <-- aquí la "cachas"
      if (!db) {
        document.getElementById("mdb").textContent = "🟠 BD (sin datos)";
        return;
      }

      if (db.online) {
        document.getElementById("mdb").textContent =
          "🟢 BD MySQL (canConnect: " + db.canConnect + ")";
      
          document.getElementById("activeTenants").textContent = db.tenants ;
          document.getElementById("avgTimbrados").textContent = db.promedio ;
          document.getElementById("stampedToday").textContent = db.ultimos24 ;
           document.getElementById("errorRate").textContent = db.rateerrores ;

             document.getElementById("errores24").textContent = db.errores24 + " errores las ultimas 24 horas" ;

      } else {
        document.getElementById("mdb").textContent =
          "🔴 BD MySQL (" + (db.error ?? "error") + ")";
      }
    }

    revisar();
    setInterval(revisar, 30000);
</script>