@page "/Monitor/Tenants/{tenantId:int}/Certificados/Details/{certId:int}"
@model Vigma.TimbradoGateway.Pages.Monitor.Tenants.Certificados.DetailsModel
@{
    ViewData["Title"] = $"Detalle de Certificado - {Model.RFC}";
}

<style>
    .card {
        border: none;
        border-radius: 8px;
    }

    .card-header {
        border-radius: 8px 8px 0 0 !important;
    }

    code {
        font-size: 0.9em;
        color: #d63384;
    }

    pre {
        font-size: 0.85em;
        max-height: 200px;
        overflow-y: auto;
    }

    dt {
        font-weight: 600;
        color: #495057;
    }

    dd {
        color: #212529;
    }
</style>

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Monitor/Tenants/Index">Tenants</a></li>
            <li class="breadcrumb-item"><a asp-page="/Monitor/Tenants/Details" asp-route-id="@Model.TenantId">@Model.TenantNombre</a></li>
            <li class="breadcrumb-item active">Certificado @Model.RFC</li>
        </ol>
    </nav>

    <!-- Título -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-file-earmark-lock2"></i>
            Detalle de Certificado
        </h2>
        <div>
            @if (Model.Activo)
            {
                <span class="badge bg-success fs-6">ACTIVO</span>
            }
            else
            {
                <span class="badge bg-secondary fs-6">INACTIVO</span>
            }

            @if (Model.CertificadoLeido && Model.EsValido)
            {
                <span class="badge bg-success fs-6 ms-2">✓ VÁLIDO</span>
            }
            else if (Model.CertificadoLeido && !Model.EsValido)
            {
                <span class="badge bg-danger fs-6 ms-2">✗ EXPIRADO</span>
            }
        </div>
    </div>

    <!-- Mensajes de Error/Advertencia -->
    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Error:</strong> @Model.MensajeError
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.MensajeAdvertencia))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill"></i>
            <strong>Advertencia:</strong> @Model.MensajeAdvertencia
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Columna Izquierda: Información Principal -->
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Información Principal</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">RFC:</dt>
                        <dd class="col-sm-8"><strong class="text-primary">@Model.RFC</strong></dd>

                        <dt class="col-sm-4">Razón Social:</dt>
                        <dd class="col-sm-8">@Model.RazonSocial</dd>

                        <dt class="col-sm-4">Tenant:</dt>
                        <dd class="col-sm-8">@Model.TenantNombre</dd>

                        <dt class="col-sm-4">Estado:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Información del Certificado -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Datos del Certificado</h5>
                </div>
                <div class="card-body">
                    @if (Model.CertificadoLeido)
                    {
                        <dl class="row mb-0">
                            <dt class="col-sm-5">No. Certificado:</dt>
                            <dd class="col-sm-7"><code>@Model.NoCertificado</code></dd>

                            <dt class="col-sm-5">Vigencia Inicio:</dt>
                            <dd class="col-sm-7">
                                @if (Model.VigenciaInicioUtc.HasValue)
                                {
                                    <span>@Model.VigenciaInicioUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
                                }
                                else
                                {
                                    <span class="text-muted">No disponible</span>
                                }
                            </dd>

                            <dt class="col-sm-5">Vigencia Fin:</dt>
                            <dd class="col-sm-7">
                                @if (Model.VigenciaFinUtc.HasValue)
                                {
                                    <span>@Model.VigenciaFinUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>

                                    @* Mostrar días restantes si está vigente *@
                                    @if (Model.EsValido)
                                    {
                                        var diasRestantes = (Model.VigenciaFinUtc.Value - DateTime.UtcNow).Days;
                                        <br />
                                        <small class="text-muted">
                                            (@diasRestantes días restantes)
                                        </small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No disponible</span>
                                }
                            </dd>

                            <dt class="col-sm-5">Estado de Validez:</dt>
                            <dd class="col-sm-7">
                                @if (Model.EsValido)
                                {
                                    <span class="badge bg-success">✓ VÁLIDO</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">✗ EXPIRADO O NO VÁLIDO</span>
                                }
                            </dd>
                        </dl>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle"></i>
                            No se pudo leer el archivo del certificado.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Archivos y Detalles Técnicos -->
        <div class="col-lg-6">
            <!-- Archivos -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-folder2-open"></i> Archivos</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Certificado (.cer):</dt>
                        <dd class="col-sm-8">
                            <code class="text-break">@Model.CerPath</code>
                            @if (System.IO.File.Exists(Model.CerPath))
                            {
                                <span class="badge bg-success ms-2">✓ Existe</span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-2">✗ No encontrado</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Llave (.key):</dt>
                        <dd class="col-sm-8">
                            <code class="text-break">@Model.KeyPath</code>
                            @if (System.IO.File.Exists(Model.KeyPath))
                            {
                                <span class="badge bg-success ms-2">✓ Existe</span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-2">✗ No encontrado</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Detalles Técnicos (Subject e Issuer) -->
            @if (Model.CertificadoLeido)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-code-square"></i> Detalles Técnicos</h5>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted">Subject (Titular):</h6>
                        <pre class="bg-light p-3 rounded"><code>@Model.CertSubject</code></pre>

                        <h6 class="text-muted mt-3">Issuer (Emisor):</h6>
                        <pre class="bg-light p-3 rounded"><code>@Model.CertIssuer</code></pre>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Botones de Acción -->
    <div class="mt-4">
        <a asp-page="/Monitor/Tenants/Details" asp-route-id="@Model.TenantId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver al Tenant
        </a>
        <a asp-page="./Edit" asp-route-tenantId="@Model.TenantId" asp-route-certId="@Model.CertId" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>
    </div>
</div>



