@page "/Monitor/Tenants/{tenantId:int}/Certificados"
@model Vigma.TimbradoGateway.Pages.Monitor.Tenants.Certificados.IndexModel
@{
    ViewData["Title"] = $"Certificados - {Model.TenantNombre}";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-light rounded-pill px-4 py-2 shadow-sm">
            <li class="breadcrumb-item">
                <a href="/Monitor/Tenants" class="text-decoration-none text-primary">
                    <i class="bi bi-building"></i> Tenants
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Monitor/Tenants/Edit/@Model.TenantId" class="text-decoration-none text-primary">
                    @Model.TenantNombre
                </a>
            </li>
            <li class="breadcrumb-item active text-muted">Certificados</li>
        </ol>
    </nav>

    <!-- Header Card -->
    <div class="card border-0 shadow-lg mb-4 overflow-hidden">
        <div class="card-header-gradient py-4 px-4">
            <div class="row align-items-center">
                <div class="col-lg-8 col-md-7">
                    <div class="d-flex align-items-center">
                        <div class="icon-circle me-3">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <div>
                            <h2 class="text-white mb-1 fw-bold">Certificados Digitales</h2>
                            <p class="text-white-75 mb-0">
                                <i class="bi bi-building me-2"></i>
                                <strong>@Model.TenantNombre</strong>
                                <span class="ms-3">
                                    <i class="bi bi-collection me-1"></i>
                                    @Model.Items.Count @(Model.Items.Count == 1 ? "certificado" : "certificados")
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-5 text-md-end mt-3 mt-md-0">
                    <a href="/Monitor/Tenants/@Model.TenantId/Certificados/Create" 
                       class="btn btn-light-custom btn-lg shadow-sm">
                        <i class="bi bi-plus-circle-fill me-2"></i>
                        Agregar Certificado
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="empty-state-icon mb-4">
                    <i class="bi bi-shield-x"></i>
                </div>
                <h4 class="text-muted mb-3">No hay certificados registrados</h4>
                <p class="text-muted mb-4">Comienza agregando tu primer certificado digital para este tenant.</p>
                <a href="/Monitor/Tenants/@Model.TenantId/Certificados/Create" 
                   class="btn btn-primary-custom btn-lg shadow">
                    <i class="bi bi-plus-circle-fill me-2"></i>
                    Agregar Primer Certificado
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Certificados Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 modern-table">
                        <thead>
                            <tr>
                                <th class="ps-4">
                                    <i class="bi bi-card-text me-2"></i>RFC
                                </th>
                                <th>
                                    <i class="bi bi-toggles me-2"></i>Estado
                                </th>
                                <th>
                                    <i class="bi bi-hash me-2"></i>No. Certificado
                                </th>
                                <th>
                                    <i class="bi bi-calendar-event me-2"></i>Vigencia
                                </th>
                                <th class="text-center pe-4">
                                    <i class="bi bi-gear-fill me-2"></i>Acciones
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Items)
                            {
                                var esValido = c.VigenciaFin.HasValue && c.VigenciaFin.Value > DateTime.UtcNow;
                                var diasRestantes = c.VigenciaFin.HasValue 
                                    ? (c.VigenciaFin.Value - DateTime.UtcNow).Days 
                                    : 0;
                                var porExpirar = diasRestantes > 0 && diasRestantes <= 30;
                                
                                <tr class="align-middle">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="cert-icon me-3">
                                                <i class="bi bi-file-earmark-lock2-fill"></i>
                                            </div>
                                            <div>
                                                <strong class="text-dark">@c.RFC</strong>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (c.Activo)
                                        {
                                            <span class="badge-custom badge-success">
                                                <i class="bi bi-check-circle-fill me-1"></i>Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-custom badge-secondary">
                                                <i class="bi bi-x-circle-fill me-1"></i>Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(c.NoCertificado))
                                        {
                                            <code class="cert-number">@c.NoCertificado</code>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (c.VigenciaFin.HasValue)
                                        {
                                            <div class="d-flex align-items-center">
                                                <div>
                                                    <div class="fw-semibold text-dark">
                                                        @c.VigenciaFin.Value.ToLocalTime().ToString("dd/MM/yy")
                                                    </div>
                                                    @if (esValido)
                                                    {
                                                        if (porExpirar)
                                                        {
                                                            <small class="text-warning">
                                                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                                                Expira en @diasRestantes días
                                                            </small>
                                                        }
                                                        else
                                                        {
                                                            <small class="text-success">
                                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                                Vigente (@diasRestantes días)
                                                            </small>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <small class="text-danger">
                                                            <i class="bi bi-x-circle-fill me-1"></i>
                                                            Expirado
                                                        </small>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group-custom" role="group">
                                            <a href="/Monitor/Tenants/@Model.TenantId/Certificados/Details/@c.Id"
                                               class="btn-action btn-info"
                                               title="Ver detalles">
                                                <i class="bi bi-eye-fill"></i>
                                                <span class="btn-text">Detalles</span>
                                            </a>
                                            <a href="/Monitor/Tenants/@Model.TenantId/Certificados/Edit/@c.Id"
                                               class="btn-action btn-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-fill"></i>
                                                <span class="btn-text">Editar</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Footer Actions -->
    <div class="mt-4">
        <a href="/Monitor/Tenants/Edit/@Model.TenantId" class="btn btn-outline-secondary-custom">
            <i class="bi bi-arrow-left-circle me-2"></i>
            Volver al Tenant
        </a>
    </div>
</div>


<style>
    /* === Variables de Color === */
    :root {
        --primary-blue: #1e40af;
        --primary-blue-dark: #1e3a8a;
        --primary-blue-light: #3b82f6;
        --secondary-blue: #60a5fa;
        --light-blue: #dbeafe;
        --extra-light-blue: #eff6ff;
        --success-green: #10b981;
        --warning-orange: #f59e0b;
        --danger-red: #ef4444;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-600: #4b5563;
        --gray-700: #374151;
    }

    /* === Header Gradient === */
    .card-header-gradient {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-light) 100%);
    }

    .text-white-75 {
        color: rgba(255, 255, 255, 0.85);
    }

    /* === Icon Circle === */
    .icon-circle {
        width: 56px;
        height: 56px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }

    .icon-circle i {
        font-size: 1.75rem;
        color: white;
    }

    /* === Custom Buttons === */
    .btn-light-custom {
        background: white;
        color: var(--primary-blue);
        border: none;
        font-weight: 600;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .btn-light-custom:hover {
        background: var(--extra-light-blue);
        color: var(--primary-blue-dark);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(30, 64, 175, 0.2);
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-light) 100%);
        color: white;
        border: none;
        font-weight: 600;
        padding: 0.75rem 2rem;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .btn-primary-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(30, 64, 175, 0.3);
    }

    .btn-outline-secondary-custom {
        color: var(--gray-600);
        border: 2px solid var(--gray-200);
        background: white;
        font-weight: 600;
        padding: 0.625rem 1.5rem;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .btn-outline-secondary-custom:hover {
        background: var(--gray-50);
        border-color: var(--gray-600);
        color: var(--gray-700);
    }

    /* === Modern Table === */
    .modern-table {
        border-collapse: separate;
        border-spacing: 0;
    }

    .modern-table thead {
        background: linear-gradient(180deg, var(--extra-light-blue) 0%, white 100%);
    }

    .modern-table thead th {
        border: none;
        color: var(--primary-blue-dark);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        padding: 1.25rem 1rem;
        border-bottom: 2px solid var(--light-blue);
    }

    .modern-table tbody tr {
        transition: all 0.2s ease;
        border-bottom: 1px solid var(--gray-100);
    }

    .modern-table tbody tr:hover {
        background: var(--extra-light-blue);
        transform: scale(1.01);
        box-shadow: 0 4px 12px rgba(30, 64, 175, 0.08);
    }

    .modern-table tbody td {
        padding: 1.25rem 1rem;
        vertical-align: middle;
        border: none;
    }

    /* === Certificate Icon === */
    .cert-icon {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, var(--light-blue) 0%, var(--extra-light-blue) 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cert-icon i {
        font-size: 1.25rem;
        color: var(--primary-blue);
    }

    /* === Badge Custom === */
    .badge-custom {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.813rem;
        display: inline-flex;
        align-items: center;
    }

    .badge-success {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-secondary {
        background: var(--gray-100);
        color: var(--gray-600);
    }

    /* === Certificate Number === */
    .cert-number {
        background: var(--gray-100);
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.813rem;
        color: var(--gray-700);
        font-family: 'Courier New', monospace;
    }

    /* === Action Buttons === */
    .btn-group-custom {
        display: flex;
        gap: 0.5rem;
    }

    .btn-action {
        padding: 0.625rem 1.25rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.875rem;
        border: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        white-space: nowrap;
    }

    .btn-action i {
        font-size: 1rem;
    }

    .btn-action.btn-info {
        background: linear-gradient(135deg, #0ea5e9 0%, #38bdf8 100%);
        color: white;
    }

    .btn-action.btn-info:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
    }

    .btn-action.btn-primary {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-light) 100%);
        color: white;
    }

    .btn-action.btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(30, 64, 175, 0.3);
    }

    /* === Empty State === */
    .empty-state-icon i {
        font-size: 5rem;
        color: var(--gray-200);
    }

    /* === Breadcrumb Custom === */
    .breadcrumb {
        margin-bottom: 0;
        background: white;
        border: 1px solid var(--gray-200);
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        color: var(--gray-600);
        font-weight: bold;
    }

    /* === Responsive === */
    @@media (max-width: 768px) {
        .btn-action .btn-text {
            display: none;
        }

        .btn-action {
            padding: 0.625rem;
            border-radius: 8px;
        }

        .btn-group-custom {
            gap: 0.375rem;
        }

        .cert-icon {
            width: 36px;
            height: 36px;
        }

        .icon-circle {
            width: 48px;
            height: 48px;
        }
    }

    /* === Card Shadow === */
    .card {
        border-radius: 16px;
    }

    .shadow-sm {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08) !important;
    }

    .shadow-lg {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12) !important;
    }
</style>


@section Scripts {
<script>
    // Opcional: Añadir tooltips de Bootstrap si los tienes configurados
    document.addEventListener('DOMContentLoaded', function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
</script>
}
