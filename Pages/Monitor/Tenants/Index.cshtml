@page
@model Vigma.TimbradoGateway.Pages.Monitor.Tenants.IndexModel
@{
    ViewData["Title"] = "Tenants";
}

<!-- =========================================================================
     TENANTS DASHBOARD
     Usando clases utilitarias de gstyle.css
     ========================================================================= -->
<link href="~/css/gstyle.css" rel="stylesheet" />
<div class="main-content">
    <!-- Hero Section con gradiente Vigma -->
    <div class="vg-card vg-mb-5" style="background: var(--vigma-gradient); border: none;">
        <div class="vg-p-5">
            <div class="vg-flex vg-justify-between vg-align-center" style="flex-wrap: wrap; gap: var(--space-4);">
                <div class="vg-flex vg-align-center vg-gap-3">
                    <div class="icon-circle-lg" style="background: rgba(255,255,255,0.15);">
                        <i class="bi bi-buildings-fill"></i>
                    </div>
                    <div>
                        <h1 class="text-white vg-display vg-mb-1">Gestión de Tenants</h1>
                        <div class="vg-flex vg-gap-2" style="flex-wrap: wrap;">
                            <span class="badge-light">
                                <i class="bi bi-collection me-1"></i> 
                                @Model.Items.Count @(Model.Items.Count == 1 ? "tenant" : "tenants")
                            </span>
                            <span class="badge-light">
                                <i class="bi bi-check-circle-fill me-1 text-success"></i> 
                                @Model.Items.Count(t => t.Activo) activos
                            </span>
                            <span class="badge-light">
                                <i class="bi bi-exclamation-triangle-fill me-1 text-warning"></i> 
                                @Model.Items.Count(t => t.CertVigenciaFinUtc.HasValue && 
                                    (t.CertVigenciaFinUtc.Value - DateTime.UtcNow).Days <= 30) por expirar
                            </span>
                             <span class="badge-light">
                                <i class="bi bi-cloud-check me-1 text-warning"></i> 
                                 @Model.Items.Count(t => t.pac_produccion) En produccion
                            </span>
                        </div>
                    </div>
                </div>
                <div>
                    <a asp-page="Create" class="vg-btn" style="background: white; color: var(--color-vigma);">
                        <i class="bi bi-plus-circle-fill"></i>
                        Nuevo Tenant
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros Card -->
    <div class="vg-card vg-mb-4">
        <div class="vg-p-4">
            <form method="get">
                <div class="vg-row gap-sm">
                    <div class="vg-col-12 vg-col-md-6 vg-col-lg-4">
                        <label class="vg-flex vg-align-center vg-gap-2 vg-mb-2 vg-text-muted vg-fw-semibold">
                            <i class="bi bi-search"></i> Buscar
                        </label>
                        <input type="text" 
                               name="q" 
                               value="@Model.Q" 
                               placeholder="Nombre, RFC o API Key..."
                               class="form-control-custom" />
                    </div>

                    <div class="vg-col-12 vg-col-md-6 vg-col-lg-3">
                        <label class="vg-flex vg-align-center vg-gap-2 vg-mb-2 vg-text-muted vg-fw-semibold">
                            <i class="bi bi-funnel"></i> Estado
                        </label>
                        <select name="activo" class="form-select-custom">
                            <option value="">Todos los estados</option>
                            <option value="1" selected="@(Model.Activo == 1)">Activos</option>
                            <option value="0" selected="@(Model.Activo == 0)">Inactivos</option>
                        </select>
                    </div>

                    <div class="vg-col-12 vg-col-lg-5">
                        <label class="vg-flex vg-align-center vg-gap-2 vg-mb-2" style="opacity: 0;">Acciones</label>
                        <div class="vg-flex vg-gap-2">
                            <button type="submit" class="vg-btn vg-btn-primary" style="flex: 1;">
                                <i class="bi bi-search"></i>
                                Buscar
                            </button>
                            <a href="/Monitor/Tenants" class="vg-btn vg-btn-outline">
                                <i class="bi bi-arrow-counterclockwise"></i>
                                Limpiar
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

  

    @if (!Model.Items.Any())
    {
        <!-- Empty State -->
        <div class="vg-card vg-text-center">
            <div class="vg-p-7">
                <div class="empty-state-icon">
                    <i class="bi bi-building-slash"></i>
                </div>
                <h2 class="vg-display vg-mb-2">No hay tenants para mostrar</h2>
                <p class="vg-text-muted vg-mb-4">
                    @if (!string.IsNullOrEmpty(Model.Q) || Model.Activo.HasValue)
                    {
                        <span>No se encontraron resultados con los filtros aplicados.</span>
                    }
                    else
                    {
                        <span>Comienza agregando tu primer tenant al sistema.</span>
                    }
                </p>
                
                @if (!string.IsNullOrEmpty(Model.Q) || Model.Activo.HasValue)
                {
                    <a href="/Monitor/Tenants" class="vg-btn" style="background: var(--color-dark); color: white;">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        Limpiar filtros
                    </a>
                }
                else
                {
                    <a asp-page="Create" class="vg-btn vg-btn-primary">
                        <i class="bi bi-plus-circle-fill"></i>
                        Crear Primer Tenant
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Tabla de Tenants -->
        <div class="vg-card">
            <div class="vg-p-4" style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                <div class="vg-flex vg-justify-between vg-align-center">
                    <h3 class="vg-flex vg-align-center vg-gap-2" style="font-family: var(--font-titles); color: var(--color-dark);">
                        <i class="bi bi-table" style="color: var(--color-vigma);"></i>
                        Listado de Tenants
                    </h3>
                    <button onclick="refreshData()" class="btn-icon">
                        <i class="bi bi-arrow-repeat"></i>
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tenant</th>
                            <th>Estado</th>
                            <th>API Key</th>
                            <th>RFCs</th>
                            <th>Vigencia</th>
                            <th>Modo</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Items)
                        {
                            var vigencia = t.CertVigenciaFinUtc.HasValue 
                                ? (t.CertVigenciaFinUtc.Value - DateTime.UtcNow).Days 
                                : (int?)null;
                            
                            <tr class="table-row">
                                <td>
                                    <span class="id-badge">@t.Id</span>
                                </td>
                                
                                <td>
                                    <div class="vg-flex vg-align-center vg-gap-2">
                                        <div class="tenant-avatar">
                                            @t.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="tenant-name">@t.Nombre</div>
                                            @if (!string.IsNullOrEmpty(t.RfcsResumen))
                                            {
                                                <div class="tenant-rfc">@t.RfcsResumen</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                
                                <td>
                                    @if (t.Activo)
                                    {
                                        <span class="status-badge status-active">
                                            <i class="bi bi-check-circle-fill"></i>
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">
                                            <i class="bi bi-x-circle-fill"></i>
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                
                                <td>
                                    <div class="api-key-container">
                                        <code class="api-key-code">@t.ApiKeyMasked</code>
                                        <button onclick="copyApiKey('@t.ApiKeyMasked')" class="api-key-btn" title="Copiar API Key">
                                            <i class="bi bi-files"></i>
                                        </button>
                                        <a asp-page="Edit" asp-route-id="@t.Id" class="api-key-btn" title="Ver API Key completa">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                                
                                <td>
                                    @if (!string.IsNullOrEmpty(t.RfcsResumen))
                                    {
                                        <span class="rfc-badge">@t.RfcsResumen</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                
                                <td>
                                    @if (t.CertVigenciaFinUtc.HasValue)
                                    {
                                        var vigenciaClass = vigencia > 30 ? "vigencia-success" : (vigencia > 0 ? "vigencia-warning" : "vigencia-danger");
                                        
                                        <div class="vigencia-container @vigenciaClass">
                                            <div class="vigencia-date">
                                                @t.CertVigenciaFinUtc.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                            </div>
                                            <div class="vigencia-status">
                                                @if (vigencia > 0)
                                                {
                                                    <i class="bi bi-@(vigencia > 30 ? "check-circle-fill" : "exclamation-triangle-fill")"></i>
                                                    <span>@vigencia días</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill"></i>
                                                    <span>Expirado</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin certificado</span>
                                    }
                                </td>
                                
                                <td>
                                    <span class="mode-badge @(t.pac_produccion ? "mode-production" : "mode-test")">
                                        <i class="bi bi-@(t.pac_produccion ? "cloud-check" : "cloud-slash")"></i>
                                        @(t.pac_produccion ? "Prod" : "Test")
                                    </span>
                                </td>
                                
                                <td>
                                    <div class="action-dropdown">
                                        <button class="action-btn" onclick="toggleDropdown(this)">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a asp-page="Edit" asp-route-id="@t.Id" class="dropdown-item">
                                                <i class="bi bi-pencil-fill"></i>
                                                Editar
                                            </a>
                                            <a href="/Monitor/Tenants/@t.Id/Certificados" class="dropdown-item">
                                                <i class="bi bi-shield-lock-fill"></i>
                                                Certificados
                                            </a>
                                            <a href="/Errores?tenantId=@t.Id" class="dropdown-item">
                                                <i class="bi bi-exclamation-triangle-fill"></i>
                                                Errores
                                            </a>
                                            <a href="/Timbrados?tenantId=@t.Id" class="dropdown-item">
                                                <i class="bi bi-file-text-fill"></i>
                                                Timbrados
                                            </a>
                                            <div class="dropdown-divider"></div>
                                            <button type="button" class="dropdown-item" onclick="consultarSaldo('@t.Id', '@t.Nombre')">
                                                <i class="bi bi-cash-stack"></i>
                                                Consultar Saldo
                                            </button>
                                            @if (t.Activo)
                                            {
                                                <button type="button" class="dropdown-item text-warning" onclick="toggleTenantStatus('@t.Id', true)">
                                                    <i class="bi bi-pause-fill"></i>
                                                    Suspender
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="dropdown-item text-success" onclick="toggleTenantStatus('@t.Id', false)">
                                                    <i class="bi bi-play-fill"></i>
                                                    Activar
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
/* ============================================================================
   ESTILOS ESPECÍFICOS PARA TENANTS
   (Solo estilos que no están en gstyle.css)
   ============================================================================ */

/* Icono circular grande */
.icon-circle-lg {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
}

.icon-circle-lg i {
    font-size: 2rem;
    color: white;
}

/* Badge claro para header */
.badge-light {
    background: rgba(255, 255, 255, 0.15);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    color: white;
    font-size: var(--text-sm);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
}

/* Form controls personalizados */
.form-control-custom,
.form-select-custom {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    border: 2px solid #e9ecef;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    transition: var(--transition-smooth);
    background: white;
}

.form-control-custom:focus,
.form-select-custom:focus {
    outline: none;
    border-color: var(--color-vigma);
    box-shadow: 0 0 0 3px rgba(91, 91, 214, 0.1);
}

/* Tarjetas de estadísticas */
.stat-card {
    position: relative;
    overflow: hidden;
}

.stat-card-header {
    height: 4px;
    width: 100%;
}

.stat-icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-icon-wrapper i {
    font-size: 1.5rem;
}

.stat-label {
    font-size: var(--text-xs);
    color: #6c757d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-value {
    font-size: var(--text-2xl);
    font-family: var(--font-titles);
    font-weight: var(--weight-bold);
    color: var(--color-dark);
    line-height: 1.2;
}

/* Tabla moderna */
.modern-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 1200px;
}

.modern-table th {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    background: var(--bg-light-subtle);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: #6c757d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.modern-table td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid rgba(0,0,0,0.05);
}

.table-row {
    transition: var(--transition-fast);
}

.table-row:hover {
    background: var(--bg-light-subtle);
}

/* Avatar de tenant */
.tenant-avatar {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, rgba(91,91,214,0.1) 0%, rgba(139,47,201,0.1) 100%);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--weight-bold);
    color: var(--color-vigma);
}

.tenant-name {
    font-weight: var(--weight-semibold);
    color: var(--color-dark);
    font-size: var(--text-sm);
}

.tenant-rfc {
    font-size: var(--text-xs);
    color: #6c757d;
}

/* ID Badge */
.id-badge {
    background: var(--bg-light-subtle);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-dark);
}

/* Status Badges */
.status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
}

.status-active {
    background: rgba(17, 153, 142, 0.1);
    color: var(--color-success);
}

.status-inactive {
    background: #e9ecef;
    color: #6c757d;
}

/* API Key */
.api-key-container {
    display: flex;
    align-items: center;
    gap: var(--space-1);
}

.api-key-code {
    background: var(--bg-light-subtle);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--color-dark);
    font-family: 'Courier New', monospace;
}

.api-key-btn {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    color: #6c757d;
    cursor: pointer;
    transition: var(--transition-fast);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
}

.api-key-btn:hover {
    background: var(--bg-light-subtle);
    color: var(--color-vigma);
}

/* RFC Badge */
.rfc-badge {
    background: var(--bg-light-subtle);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--color-dark);
}

/* Vigencia */
.vigencia-container {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
    display: inline-block;
}

.vigencia-success {
    background: rgba(17, 153, 142, 0.1);
    color: var(--color-success);
}

.vigencia-warning {
    background: rgba(247, 151, 30, 0.1);
    color: var(--color-warning);
}

.vigencia-danger {
    background: rgba(255, 65, 108, 0.1);
    color: var(--color-danger);
}

.vigencia-date {
    font-weight: var(--weight-semibold);
    color: var(--color-dark);
    font-size: var(--text-sm);
}

.vigencia-status {
    font-size: var(--text-xs);
    display: flex;
    align-items: center;
    gap: 2px;
}

/* Mode Badge */
.mode-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
}

.mode-production {
    background: rgba(15, 155, 142, 0.1);
    color: var(--color-throughput);
}

.mode-test {
    background: #e9ecef;
    color: #6c757d;
}

/* Action Dropdown */
.action-dropdown {
    position: relative;
    display: inline-block;
}

.action-btn {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 2px solid #e9ecef;
    background: transparent;
    color: #6c757d;
    cursor: pointer;
    transition: var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
}

.action-btn:hover {
    border-color: var(--color-vigma);
    color: var(--color-vigma);
}

.dropdown-menu {
    position: absolute;
    right: 0;
    top: 100%;
    min-width: 200px;
    background: white;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0,0,0,0.05);
    z-index: 1000;
    display: none;
    margin-top: var(--space-1);
}

.dropdown-menu.show {
    display: block;
}

.dropdown-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    color: var(--color-dark);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: var(--transition-fast);
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
}

.dropdown-item:hover {
    background: var(--bg-light-subtle);
    color: var(--color-vigma);
}

.dropdown-divider {
    height: 1px;
    background: rgba(0,0,0,0.05);
    margin: var(--space-1) 0;
}

/* Empty State */
.empty-state-icon {
    width: 120px;
    height: 120px;
    background: var(--bg-light-subtle);
    border-radius: var(--radius-full);
    margin: 0 auto var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
}

.empty-state-icon i {
    font-size: 3rem;
    color: #adb5bd;
}

/* Botón icono */
.btn-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 2px solid #e9ecef;
    background: transparent;
    color: #6c757d;
    cursor: pointer;
    transition: var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
}

.btn-icon:hover {
    border-color: var(--color-vigma);
    color: var(--color-vigma);
}

/* Utilidades adicionales */
.text-white {
    color: white !important;
}

.text-center {
    text-align: center;
}

.text-muted {
    color: #adb5bd;
}

.table-responsive {
    overflow-x: auto;
}

/* Animaciones */
@@keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.rotating {
    animation: rotate 1s linear infinite;
}

/* Responsive */
@@media (max-width: 768px) {
    .badge-light {
        width: 100%;
    }
    
    .action-btn {
        width: 32px;
        height: 32px;
    }
}
</style>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Configuración
    const CONFIG = {
        apiBase: '/api/tenants'
    };

    // Toggle dropdown
    function toggleDropdown(button) {
        const dropdown = button.closest('.action-dropdown');
        const menu = dropdown.querySelector('.dropdown-menu');
        
        // Cerrar otros dropdowns
        document.querySelectorAll('.dropdown-menu.show').forEach(m => {
            if (m !== menu) m.classList.remove('show');
        });
        
        menu.classList.toggle('show');
    }

    // Cerrar dropdowns al hacer click fuera
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.action-dropdown')) {
            document.querySelectorAll('.dropdown-menu.show').forEach(menu => {
                menu.classList.remove('show');
            });
        }
    });

    // Copiar API Key
    function copyApiKey(apiKey) {
        navigator.clipboard.writeText(apiKey).then(() => {
            Swal.fire({
                icon: 'success',
                title: '¡Copiado!',
                text: 'API Key copiada al portapapeles',
                timer: 1500,
                showConfirmButton: false
            });
        }).catch(() => {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'No se pudo copiar la API Key'
            });
        });
    }

    // Consultar saldo
    async function consultarSaldo(tenantId, nombre) {
        const result = await Swal.fire({
            title: 'Consultar Saldo',
            text: `Tenant: ${nombre}`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Consultar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: 'var(--color-vigma)'
        });

        if (!result.isConfirmed) return;

        Swal.fire({
            title: 'Consultando...',
            text: 'Por favor espere',
            allowOutsideClick: false,
            showConfirmButton: false,
            didOpen: () => Swal.showLoading()
        });

        try {
            const response = await fetch(`${CONFIG.apiBase}/${tenantId}/saldo`);
            const data = await response.json();

            if (!response.ok) throw new Error(data.message || 'Error en la consulta');

            Swal.fire({
                icon: 'success',
                title: 'Saldo Consultado',
                html: `
                    <div style="text-align: center;">
                        <div style="color: #6c757d; font-size: 0.875rem; margin-bottom: 0.5rem;">${data.tenantNombre || nombre}</div>
                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-vigma); margin-bottom: 0.5rem;">${data.saldo} timbres</div>
                        ${data.mensaje ? `<div style="background: var(--bg-light-subtle); padding: 0.75rem; border-radius: var(--radius-md); color: #6c757d; font-size: 0.875rem;">${data.mensaje}</div>` : ''}
                    </div>
                `,
                confirmButtonColor: 'var(--color-vigma)'
            });
        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: error.message || 'No se pudo consultar el saldo',
                confirmButtonColor: 'var(--color-danger)'
            });
        }
    }

    // Toggle tenant status
    function toggleTenantStatus(tenantId, isActive) {
        const action = isActive ? 'suspender' : 'activar';
        
        Swal.fire({
            title: `¿${action} tenant?`,
            text: `¿Estás seguro de que deseas ${action} este tenant?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: isActive ? 'var(--color-warning)' : 'var(--color-success)',
            cancelButtonColor: '#6c757d',
            confirmButtonText: `Sí, ${action}`,
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                // Obtener token anti-forgery
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                
                fetch(`/Monitor/Tenants/ToggleActivo/${tenantId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    }
                })
                .then(response => {
                    if (response.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: '¡Completado!',
                            text: `Tenant ${action}do correctamente`,
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        throw new Error('Error al procesar la solicitud');
                    }
                })
                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: error.message
                    });
                });
            }
        });
    }

    // Refresh data
    function refreshData() {
        const btn = event.currentTarget;
        const icon = btn.querySelector('i');
        icon.classList.add('rotating');
        
        fetch(window.location.href, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.text())
        .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newTable = doc.querySelector('.vg-card:last-child');
            const oldTable = document.querySelector('.vg-card:last-child');
            
            if (newTable && oldTable) {
                oldTable.innerHTML = newTable.innerHTML;
            }
        })
        .finally(() => {
            icon.classList.remove('rotating');
        });
    }
</script>
}