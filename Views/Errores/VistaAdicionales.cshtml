@model Vigma.TimbradoGateway.ViewsModels.Errores.TimbradoErrorLogRowVM
 @{   ViewData["Title"] = $"Error #{Model.Id} - Detalle";
}

<link href="~/css/detalleerror.css" rel="stylesheet" />

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="error-detail-header">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="error-badge-large mb-3">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i>Error de Timbrado
                </span>
                <h1 class="display-6 fw-bold mb-3">Detalle del Error #@Model.Id</h1>
                <div class="d-flex flex-wrap gap-3 align-items-center">
                    <span class="time-badge">
                        <i class="bi bi-clock me-2"></i>
                        @Model.CreadoUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </span>
                    <a href="@Url.Action("Indice", "Errores")" class="btn-icon">
                        <i class="bi bi-arrow-left"></i> Volver al índice
                    </a>
                </div>
            </div>
            <div class="col-md-4 text-end">
                @if (Model.CodigoMfNumero.HasValue)
                {
                    <div class="error-code-badge">
                        Código: @Model.CodigoMfNumero
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Información del Error -->
    <div class="row">
        <div class="col-md-4">
            <div class="info-card">
                <div class="card-title">
                    <i class="bi bi-people-fill"></i> Información del Tenant
                </div>
                <div class="card-value mb-3">ID: @Model.TenantId</div>
                <div class="card-title">
                    <i class="bi bi-building"></i> RFC Emisor
                </div>
                <div class="card-value">
                    <span class="rfc-badge">@Model.RfcEmisor</span>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="info-card h-100">
                <div class="card-title">
                    <i class="bi bi-chat-dots-fill"></i> Mensaje de Error
                </div>
                <div class="card-value">
                    @if (!string.IsNullOrEmpty(Model.CodigoMfTexto))
                    {
                        <div class="alert alert-danger bg-opacity-10 border-danger" style="border-radius: 12px;">
                            <div class="d-flex">
                                <i class="bi bi-exclamation-triangle-fill text-danger me-3 fs-5"></i>
                                <div>@Model.CodigoMfTexto</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted fst-italic">
                            No hay mensaje de error disponible
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- JSON Viewer -->
    <div class="json-editor-container">
        <div class="json-header">
            <div>
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-code-slash me-2"></i> Datos Adicionales
                </h5>
                <small class="opacity-75">Contenido Adicional enviado para el timbrado</small>
            </div>
            <div class="badge bg-warning">
               @(string.IsNullOrWhiteSpace(Model.Adicionales) ? "JSON Inválido" : "JSON Válido")

            </div>
        </div>

        <div class="json-toolbar">
            <button class="btn-icon btn-copy" onclick="copiarJSON()">
                <i class="bi bi-clipboard"></i> Copiar JSON
            </button>
            <button class="btn-icon btn-download" onclick="descargarJSON()">
                <i class="bi bi-download"></i> Descargar
            </button>
            <button class="btn-icon btn-reload" onclick="formatearJSON()">
                <i class="bi bi-arrow-clockwise"></i> Re-formatear
            </button>
            <button class="btn-icon" onclick="alternarJSON()">
                <i class="bi bi-eye"></i> Alternar vista
            </button>
            <div class="ms-auto">
                <span class="text-muted small">
                    Tamaño: <span id="jsonSize">0</span> caracteres
                </span>
            </div>
        </div>

        <div class="json-content" id="jsonViewer">
            @if (!string.IsNullOrEmpty(Model.JsonFormateado))
            {
                <pre id="jsonContent">@Html.Raw(SyntaxHighlightJson(Model.JsonFormateado))</pre>
            }
            else if (!string.IsNullOrEmpty(Model.Adicionales))
            {
                <div class="text-center py-5">
                    <div class="empty-json">
                        <i class="bi bi-file-earmark-x empty-json-icon"></i>
                        <h5 class="fw-bold mb-2">JSON no formateado</h5>
                        <p class="text-muted mb-4">El JSON no pudo ser formateado automáticamente</p>
                        <button class="btn btn-primary" onclick="formatearJSON()">
                            <i class="bi bi-magic me-2"></i> Intentar formatear
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="empty-json">
                        <i class="bi bi-file-earmark-x empty-json-icon"></i>
                        <h5 class="fw-bold mb-2">No hay JSON disponible</h5>
                        <p class="text-muted">No se encontró contenido Adicional para este error</p>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Bootstrap JS para modal -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@functions {
    public string SyntaxHighlightJson(string json)
    {
        if (string.IsNullOrEmpty(json)) return json;

        // Reemplazar caracteres especiales para colorear
        json = json.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");

        // Patrones para colorear
        json = System.Text.RegularExpressions.Regex.Replace(json,
            @"(\s*)(\""(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\""])*\"")",
            match =>
            {
                var cls = "json-string";
                return match.Groups[1].Value + "<span class=\"" + cls + "\">" +
                       match.Groups[2].Value + "</span>";
            });

        json = System.Text.RegularExpressions.Regex.Replace(json,
            @"\b(true|false|null)\b",
            "<span class=\"json-boolean\">$&</span>");

        json = System.Text.RegularExpressions.Regex.Replace(json,
            @"\b-?\d+(\.\d+)?([eE][+-]?\d+)?\b",
            "<span class=\"json-number\">$&</span>");

        json = System.Text.RegularExpressions.Regex.Replace(json,
            @"(\""([^""\\]|\\.)*\"")",
            "<span class=\"json-key\">$&</span>");

        json = json.Replace(":", "<span class=\"json-punctuation\">:</span>")
                   .Replace(",", "<span class=\"json-punctuation\">,</span>")
                   .Replace("[", "<span class=\"json-punctuation\">[</span>")
                   .Replace("]", "<span class=\"json-punctuation\">]</span>")
                   .Replace("{", "<span class=\"json-punctuation\">{</span>")
                   .Replace("}", "<span class=\"json-punctuation\">}</span>");

        return json;
    }
}

<script>
    // Inicializar tamaño del JSON
    document.addEventListener('DOMContentLoaded', function() {
        const jsonContent = document.getElementById('jsonContent');
        if (jsonContent) {
            const text = jsonContent.textContent || jsonContent.innerText;
            document.getElementById('jsonSize').textContent = text.length.toLocaleString();
        }
    });

    // Copiar JSON al portapapeles
    async function copiarJSON() {
        try {
            const response = await fetch('@Url.Action("GetAdicionalesFormatted", "Errores")?id=@Model.Id');
            const data = await response.json();

            if (data.success) {
                await navigator.clipboard.writeText(data.jsonFormatted);
                mostrarNotificacion('JSON copiado al portapapeles');
            } else {
                // Si no hay JSON formateado, copiar el original
                await navigator.clipboard.writeText(`@Model.Adicionales`);
                mostrarNotificacion('JSON copiado al portapapeles');
            }
        } catch (error) {
            mostrarNotificacion('Error al copiar: ' + error.message, 'error');
        }
    }

    // Descargar JSON como archivo
    function descargarJSON() {
        const jsonContent = `@Model.Adicionales`;
        const blob = new Blob([jsonContent], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `Adicionales del error_@Model.Id `;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    // Formatear JSON dinámicamente
    async function formatearJSON() {
        try {
            const response = await fetch('@Url.Action("GetAdicionalesFormatted", "Errores")?id=@Model.Id');
            const data = await response.json();

            if (data.success) {
                const jsonViewer = document.getElementById('jsonViewer');
                jsonViewer.innerHTML = `<pre id="jsonContent">${syntaxHighlight(data.jsonFormatted)}</pre>`;
                document.getElementById('jsonSize').textContent = data.jsonFormatted.length.toLocaleString();
                mostrarNotificacion('JSON formateado correctamente');
            } else {
                mostrarNotificacion('Error al formatear JSON', 'error');
            }
        } catch (error) {
            mostrarNotificacion('Error: ' + error.message, 'error');
        }
    }

    // Alternar entre vista formateada y cruda
    function alternarJSON() {
        const modal = new bootstrap.Modal(document.getElementById('rawJsonModal'));
        const textarea = document.getElementById('rawJsonTextarea');
        textarea.value = `@Model.Adicionales`;
        modal.show();
    }

    // Copiar texto crudo
    function copiarTextoCrudo() {
        const textarea = document.getElementById('rawJsonTextarea');
        textarea.select();
        document.execCommand('copy');
        mostrarNotificacion('Texto copiado al portapapeles');
    }

    // Mostrar notificación
    function mostrarNotificacion(mensaje, tipo = 'success') {
        const div = document.createElement('div');
        div.className = 'copy-success';
        div.innerHTML = `
            <div class="d-flex align-items-center">
                <i class="bi bi-${tipo === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                <span>${mensaje}</span>
            </div>
        `;
        document.body.appendChild(div);

        setTimeout(() => {
            div.remove();
        }, 3000);
    }

    // Función para colorear sintaxis (similar a la del servidor)
    function syntaxHighlight(json) {
        if (!json) return '';

        json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

        return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?)/g, function(match) {
            let cls = 'json-key';
            if (/:$/.test(match)) {
                cls = 'json-key';
            } else {
                cls = 'json-string';
            }
            return '<span class="' + cls + '">' + match + '</span>';
        }).replace(/\b(true|false|null)\b/g, '<span class="json-boolean">$&</span>')
          .replace(/\b-?\d+(\.\d+)?([eE][+-]?\d+)?\b/g, '<span class="json-number">$&</span>')
          .replace(/[{},:\[\]]/g, function(match) {
              return '<span class="json-punctuation">' + match + '</span>';
          });
    }
</script>