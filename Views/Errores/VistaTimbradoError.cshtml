@model Vigma.TimbradoGateway.ViewsModels.Errores.TimbradoErrorLogRowVM
@{
    ViewData["Title"] = $"Error #{Model.Id} - Detalle";
    Layout = "_Layout";
}

<link href="~/css/gstyle.css" rel="stylesheet" />
<link href="~/css/errores.css" rel="stylesheet" />

<div class="errores-page">

    <!-- ── Header ── -->
    <div class="ed-header-card">
        <div class="ed-header-top">
            <span class="ed-badge-top">
                <i class="bi bi-exclamation-octagon-fill"></i> Error de Timbrado
            </span>
            <div class="ed-header-actions">
                <!-- Toggle resuelto -->
                <button class="ed-resolve-btn" id="resolveBtn" onclick="toggleResuelto()">
                    <span class="ed-resolve-indicator" id="resolveIndicator"></span>
                    <span id="resolveText">Marcar como resuelto</span>
                </button>
                <a href="@Url.Action("Indice", "Errores")" class="vg-btn vg-btn-outline">
                    <i class="bi bi-arrow-left"></i> Volver al índice
                </a>
            </div>
        </div>

        <div class="ed-header-body">
            <div class="ed-header-info">
                <h1 class="errores-title">Detalle del Error #@Model.Id</h1>
                <div class="ed-header-meta">
                    <span class="ec-time">
                        <i class="bi bi-clock"></i>
                        @Model.CreadoUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </span>
                    @if (Model.CodigoMfNumero.HasValue)
                    {
                        <span class="ec-error-code">Código: @Model.CodigoMfNumero</span>
                    }
                    <span class="ed-status-pill" id="statusPill">
                        <span class="ec-status-dot nuevo"></span>
                        <span id="statusPillText">Nuevo</span>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Info cards ── -->
    <div class="ed-info-grid">

        <!-- Tenant + RFC -->
        <div class="errores-ring-card ed-info-card">
            <div class="ed-info-section">
                <span class="ec-label">
                    <i class="bi bi-people-fill"></i> Información del Tenant
                </span>
                <span class="ed-info-value">ID: @Model.TenantId</span>
            </div>
            <div class="ed-divider"></div>
            <div class="ed-info-section">
                <span class="ec-label">
                    <i class="bi bi-building"></i> RFC Emisor
                </span>
                <code class="ec-rfc ed-rfc-large">@Model.RfcEmisor</code>
            </div>
        </div>

        <!-- Mensaje de error -->
        <div class="errores-ring-card ed-info-card ed-info-card-wide">
            <div class="ed-info-section">
                <span class="ec-label">
                    <i class="bi bi-chat-dots-fill"></i> Mensaje de Error
                </span>
                @if (!string.IsNullOrEmpty(Model.CodigoMfTexto))
                {
                    <div class="ed-error-msg">
                        <i class="bi bi-exclamation-triangle-fill ed-error-icon"></i>
                        <p>@Model.CodigoMfTexto</p>
                    </div>
                }
                else
                {
                    <p class="ed-empty-msg">No hay mensaje de error disponible</p>
                }
            </div>
        </div>

    </div>

    <!-- ── JSON Viewer ── -->
    <div class="ed-json-card">

        <div class="ed-json-header">
            <div>
                <h4 class="ed-json-title">
                    <i class="bi bi-code-slash"></i> JSON Enviado al PAC
                </h4>
                <span class="ed-json-sub">Contenido completo enviado para el timbrado</span>
            </div>
            <span class="ed-json-badge @(Model.EsJsonValido ? "ed-json-valid" : "ed-json-invalid")">
                @(Model.EsJsonValido ? "JSON Válido" : "JSON Inválido")
            </span>
        </div>

        <div class="ed-json-toolbar">
            <button class="ed-tool-btn" onclick="copiarJSON()">
                <i class="bi bi-clipboard"></i> Copiar JSON
            </button>
            <button class="ed-tool-btn" onclick="descargarJSON()">
                <i class="bi bi-download"></i> Descargar
            </button>
            <button class="ed-tool-btn" onclick="formatearJSON()">
                <i class="bi bi-arrow-clockwise"></i> Re-formatear
            </button>
            <button class="ed-tool-btn" onclick="alternarJSON()">
                <i class="bi bi-eye"></i> Alternar vista
            </button>
            <span class="ed-json-size">
                Tamaño: <strong id="jsonSize">0</strong> caracteres
            </span>
        </div>

        <div class="ed-json-content" id="jsonViewer">
            @if (!string.IsNullOrEmpty(Model.JsonFormateado))
            {
                <pre id="jsonContent">@Html.Raw(SyntaxHighlightJson(Model.JsonFormateado))</pre>
            }
            else if (!string.IsNullOrEmpty(Model.Jsonenviado))
            {
                <div class="ed-json-empty">
                    <i class="bi bi-file-earmark-x ed-empty-icon"></i>
                    <h5>JSON no formateado</h5>
                    <p>El JSON no pudo ser formateado automáticamente</p>
                    <button class="vg-btn vg-btn-primary" onclick="formatearJSON()">
                        <i class="bi bi-magic"></i> Intentar formatear
                    </button>
                </div>
            }
            else
            {
                <div class="ed-json-empty">
                    <i class="bi bi-file-earmark-x ed-empty-icon"></i>
                    <h5>No hay JSON disponible</h5>
                    <p>No se encontró contenido JSON para este error</p>
                </div>
            }
        </div>

    </div>

</div>

@functions {
    public string SyntaxHighlightJson(string json)
    {
        if (string.IsNullOrEmpty(json)) return json;
        json = json.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
        json = System.Text.RegularExpressions.Regex.Replace(json,
            @"(\s*)(\""(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\""])*\"")",
            match =>
            {
                var cls = "json-string";
                return match.Groups[1].Value + "<span class=\"" + cls + "\">" + match.Groups[2].Value + "</span>";
            });
        json = System.Text.RegularExpressions.Regex.Replace(json, @"\b(true|false|null)\b", "<span class=\"json-boolean\">$&</span>");
        json = System.Text.RegularExpressions.Regex.Replace(json, @"\b-?\d+(\.\d+)?([eE][+-]?\d+)?\b", "<span class=\"json-number\">$&</span>");
        json = System.Text.RegularExpressions.Regex.Replace(json, @"(\""([^""\\]|\\.)*\"")", "<span class=\"json-key\">$&</span>");
        json = json.Replace(":", "<span class=\"json-punctuation\">:</span>")
                   .Replace(",", "<span class=\"json-punctuation\">,</span>")
                   .Replace("[", "<span class=\"json-punctuation\">[</span>")
                   .Replace("]", "<span class=\"json-punctuation\">]</span>")
                   .Replace("{", "<span class=\"json-punctuation\">{</span>")
                   .Replace("}", "<span class=\"json-punctuation\">}</span>");
        return json;
    }
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const jsonContent = document.getElementById('jsonContent');
            if (jsonContent) {
                const text = jsonContent.textContent || jsonContent.innerText;
                document.getElementById('jsonSize').textContent = text.length.toLocaleString();
            }
        });

        async function copiarJSON() {
            try {
                const response = await fetch('@Url.Action("GetJsonFormatted", "Errores")?id=@Model.Id');
                const data = await response.json();
                await navigator.clipboard.writeText(data.success ? data.jsonFormatted : `@Model.Jsonenviado`);
                mostrarNotificacion('JSON copiado al portapapeles');
            } catch (error) {
                mostrarNotificacion('Error al copiar: ' + error.message, 'error');
            }
        }

        function descargarJSON() {
            const blob = new Blob([`@Model.Jsonenviado`], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `error_@(Model.Id)_@(DateTime.Now.ToString("yyyyMMdd_HHmmss")).json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        async function formatearJSON() {
            try {
                const response = await fetch('@Url.Action("GetJsonFormatted", "Errores")?id=@Model.Id');
                const data = await response.json();
                if (data.success) {
                    document.getElementById('jsonViewer').innerHTML = `<pre id="jsonContent">${syntaxHighlight(data.jsonFormatted)}</pre>`;
                    document.getElementById('jsonSize').textContent = data.jsonFormatted.length.toLocaleString();
                    mostrarNotificacion('JSON formateado correctamente');
                } else {
                    mostrarNotificacion('Error al formatear JSON', 'error');
                }
            } catch (error) {
                mostrarNotificacion('Error: ' + error.message, 'error');
            }
        }

        function alternarJSON() {
            const win = window.open('', '_blank');
            win.document.write('<pre style="font-family:monospace;padding:20px;">' + `@Model.Jsonenviado`.replace(/</g,'&lt;') + '</pre>');
        }

        function mostrarNotificacion(mensaje, tipo = 'success') {
            const div = document.createElement('div');
            div.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;
                background:${tipo === 'success' ? '#11998e' : '#ff416c'};color:white;
                padding:12px 20px;border-radius:12px;font-size:14px;
                box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:8px;`;
            div.innerHTML = `<i class="bi bi-${tipo === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${mensaje}`;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 3000);
        }

        function syntaxHighlight(json) {
            if (!json) return '';
            json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?)/g, m =>
                `<span class="${/:$/.test(m) ? 'json-key' : 'json-string'}">${m}</span>`)
                .replace(/\b(true|false|null)\b/g, '<span class="json-boolean">$&</span>')
                .replace(/\b-?\d+(\.\d+)?([eE][+-]?\d+)?\b/g, '<span class="json-number">$&</span>')
                .replace(/[{},:\[\]]/g, m => `<span class="json-punctuation">${m}</span>`);
        }
    </script>
}

