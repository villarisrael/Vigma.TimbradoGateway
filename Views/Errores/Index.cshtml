

@model Vigma.TimbradoGateway.ViewModels.Errores.TimbradoErrorIndiceVM
@{
    ViewData["Title"] = "Errores Crudos";
    Layout = "_Layout";
}



<link href="~/css/gstyle.css" rel="stylesheet" />
<link href="~/css/errores.css" rel="stylesheet" />

<div class="errores-page">

    <!-- ── Header ── -->
    <div class="errores-header">
        <div class="errores-header-left">
            <h1 class="errores-title">Monitor de Errores</h1>
            <span class="errores-subtitle">
                Últimos 100 errores registrados • Ordenados por <strong>creado_utc DESC</strong>
            </span>
        </div>
        <div class="errores-header-right">
            <div class="ec-stat-pill">
                <span class="ec-stat-num">100</span>
                <span class="ec-stat-label">Total</span>
            </div>
            <div class="ec-stat-pill ec-stat-danger">
                <span class="ec-stat-num">24</span>
                <span class="ec-stat-label">Últimas 24h</span>
            </div>
        </div>
    </div>

    <!-- ── Filtros ── -->
    <div class="ec-filter-card">
        <div class="ec-filter-header">
            <i class="bi bi-funnel-fill"></i>
            <span>Filtros de búsqueda</span>
        </div>

        <form asp-action="Index" asp-controller="Errores" method="get">
            <div class="ec-filter-grid">

                <div class="ec-field">
                    <label class="ec-label">
                        <i class="bi bi-people"></i> Tenant
                    </label>
                    @Html.DropDownListFor(m => m.TenantId, Model.Tenants,
                        new { @class = "ec-select" })
                </div>

                <div class="ec-field">
                    <label class="ec-label">
                        <i class="bi bi-building"></i> RFC Emisor
                    </label>
                    @Html.TextBoxFor(m => m.RfcEmisor,
                        new { @class = "ec-input", placeholder = "EKU9003173C9..." })
                </div>

                <div class="ec-field">
                    <label class="ec-label">
                        <i class="bi bi-calendar"></i> Fecha inicio
                    </label>
                    @Html.TextBoxFor(m => m.FechaInicio, "{0:yyyy-MM-dd}",
                        new { @type = "date", @class = "ec-input" })
                </div>

                <div class="ec-field">
                    <label class="ec-label">
                        <i class="bi bi-calendar-check"></i> Fecha final
                    </label>
                    @Html.TextBoxFor(m => m.FechaFinal, "{0:yyyy-MM-dd}",
                        new { @type = "date", @class = "ec-input" })
                </div>

                <div class="ec-field ec-field-actions">
                    <button type="submit" class="vg-btn vg-btn-primary">
                        <i class="bi bi-search"></i> Buscar errores
                    </button>
                    <a class="vg-btn vg-btn-outline" href="@Url.Action("Indice", "Errores")">
                        <i class="bi bi-arrow-clockwise"></i> Limpiar
                    </a>
                </div>

            </div>
        </form>
    </div>

    <!-- ── Tabla ── -->
    <div class="ec-table-card">
        <div class="ec-table-header">
            <div class="ec-table-title">
                <i class="bi bi-table"></i> Registro de errores
            </div>
            <span class="ec-table-count">
                Mostrando @(Model.Rows?.Count() ?? 0) resultados
            </span>
        </div>

        <div class="ec-table-wrap">
            <table class="ec-table">
                <thead>
                    <tr>
                        <!-- thead -->
                        <th style="width:60px;"><i class="bi bi-person-badge"></i> Tenant</th>
                        <th style="width:150px;"><i class="bi bi-building"></i> RFC Emisor</th>
                        <th style="width:80px; text-align:center;"><i class="bi bi-code"></i> Nivel</th>
                        <th><i class="bi bi-chat-dots"></i> Mensaje de error</th>
                        <th style="width:155px;"><i class="bi bi-clock-history"></i> Creado (UTC)</th>
                        <th style="width:160px;" class="ec-th-center"><i class="bi bi-gear"></i> Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows == null || !Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="ec-empty">
                                    <i class="bi bi-shield-exclamation ec-empty-icon"></i>
                                    <h5>No se encontraron errores</h5>
                                    <p>No hay errores que coincidan con los filtros seleccionados.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        int _rowIndex = 0;
                        foreach (var r in Model.Rows)
                        {
                            string _status = _rowIndex == 1 ? "visto" : _rowIndex == 2 ? "resuelto" : "nuevo";
                            _rowIndex++;

                            <tr class="ec-row" data-id="@r.Id" data-status="@_status">
                                <td><span class="ec-tenant">@r.TenantId</span></td>

                                <td><code class="ec-rfc">@r.RfcEmisor</code></td>

                                <td>
                                    <div class="ec-nivel-wrap">
                                        @if (r.CodigoMfNumero.HasValue)
                                        {
                                            <span class="ec-error-code">@r.CodigoMfNumero</span>
                                        }
                                        else
                                        {
                                            <span class="ec-na">N/A</span>
                                        }
                                        <span class="ec-status-dot @_status"></span>
                                        <span class="ec-status-label @_status">
                                            @(_status == "visto" ? "Visto" : _status == "resuelto" ? "Resuelto" : "Nuevo")
                                        </span>
                                    </div>
                                </td>

                                <td>
                                    <div class="ec-message" title="@r.CodigoMfTexto">
                                        @r.CodigoMfTexto
                                    </div>
                                </td>

                                <td>
                                    <span class="ec-time">
                                        <i class="bi bi-clock"></i>
                                        @r.CreadoUtc.ToString("yyyy-MM-dd HH:mm:ss")
                                    </span>
                                </td>

                                <td class="ec-td-center">
                                    <a class="ec-btn-action"
                                           onclick="marcarVisto('@r.Id', this)"
                                           href="@Url.Action("VistaTimbradoError", "Errores", new { id = r.Id })">
                                        <i class="bi bi-eye"></i> Detalle
                                    </a>
                                    <a class="ec-btn-action"
                                           onclick="marcarVisto('@r.Id', this)"
                                           href="@Url.Action("VistaAdicionales", "Errores", new { id = r.Id })">
                                        <i class="bi bi-plus-circle"></i> Adicionales
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Rows != null && Model.Rows.Any())
        {
            <div class="ec-table-footer">
                <span class="ec-footer-text">Mostrando los últimos 100 errores registrados</span>
                <button class="vg-btn vg-btn-outline">
                    <i class="bi bi-download"></i> Exportar CSV
                </button>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        /* ── Marcar como visto al hacer click en Detalle o Adicionales ── */
        function marcarVisto(id, btn) {
            const row = btn.closest('.ec-row');
            const dot = row.querySelector('.ec-status-dot');
            const label = row.querySelector('.ec-status-label');

            if (dot && label && row.dataset.status === 'nuevo') {
                dot.className = 'ec-status-dot visto';
                label.className = 'ec-status-label visto';
                label.textContent = 'Visto';
                row.dataset.status = 'visto';

                /* Cuando el API esté listo — descomenta:
                fetch(`/api/errores/${id}/visto`, { method: 'POST' });
                */
            }
        }

        /* ── Animación de entrada para filas ── */
        document.querySelectorAll('.ec-row').forEach((row, i) => {
            row.style.opacity = '0';
            row.style.transform = 'translateY(8px)';
            setTimeout(() => {
                row.style.transition = 'all 0.3s ease';
                row.style.opacity = '1';
                row.style.transform = 'translateY(0)';
            }, i * 40);
        });
    </script>
}