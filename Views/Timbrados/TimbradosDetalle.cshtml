@model Vigma.TimbradoGateway.ViewModels.Timbrados.TimbradoDetalleVM
@{
    ViewData["Title"] = $"Timbrado #{Model.Id} - Detalle";
    Layout = "_Layout";
    var fileNameXml = $"{Model.Uuid}.xml";
}

<link href="~/css/gstyle.css" rel="stylesheet" />
<link href="~/css/errores.css" rel="stylesheet" />
<link href="~/css/Timbrado.css" rel="stylesheet" />

<div class="errores-page">

    <!-- ── Header card ── -->
    <div class="td-header-card">
        <div class="td-header-top">
            <span class="tb-badge-top">
                <i class="bi bi-receipt-cutoff"></i> Timbrado
            </span>
            <div class="td-header-actions">
                @if (Model.Cancelada)
                {
                    <span class="tb-pill tb-pill-cancel">
                        <i class="bi bi-x-circle-fill"></i> Cancelada
                    </span>
                }
                else
                {
                    <span class="tb-pill tb-pill-ok">
                        <i class="bi bi-check-circle-fill"></i> Vigente
                    </span>
                }
                <a href="@Url.Action("Index", "Timbrados")" class="vg-btn vg-btn-outline">
                    <i class="bi bi-arrow-left"></i> Volver al índice
                </a>
            </div>
        </div>

        <div class="td-header-body">
            <div class="td-header-info">
                <h1 class="errores-title">Detalle del Timbrado #@Model.Id</h1>
                <div class="ed-header-meta">
                    <span class="ec-time">
                        <i class="bi bi-clock"></i>
                        @Model.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </span>
                    <span class="tb-pill tb-pill-mid">
                        <i class="bi bi-people"></i> Tenant: @Model.TenantId
                    </span>
                    @if (Model.Saldo.HasValue)
                    {
                        <span class="tb-pill tb-pill-mid">
                            <i class="bi bi-cash-coin"></i> Saldo: @Model.Saldo.Value.ToString("N2")
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ── Info cards (3 columnas) ── -->
    <div class="td-info-grid">

        <!-- Tarjeta 1: RFC, Origen, Tipo -->
        <div class="errores-ring-card timbrado-cards-row">
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-building"></i> RFC Emisor</span>
                <code class="ec-rfc td-rfc-large">@Model.RfcEmisor</code>
            </div>
            <div class="ed-divider"></div>
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-box-arrow-in-right"></i> Origen</span>
                <span class="ed-info-value">@(!string.IsNullOrWhiteSpace(Model.Origen) ? Model.Origen : "—")</span>
            </div>
            <div class="ed-divider"></div>
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-file-earmark-text"></i> Tipo de comprobante</span>
                @if (!string.IsNullOrWhiteSpace(Model.TipoDeComprobante))
                {
                    <span class="tb-pill tb-pill-ok" style="width:fit-content">
                        <i class="bi bi-file-earmark-check"></i> @Model.TipoDeComprobante
                    </span>
                }
                else
                {
                    <span class="ec-na">N/A</span>
                }
            </div>
        </div>

        <!-- Tarjeta 2: Serie, Folio, UUID -->
        <div class="errores-ring-card timbrado-cards-row">
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-collection"></i> Serie</span>
                <span class="ed-info-value">@(!string.IsNullOrWhiteSpace(Model.Serie) ? Model.Serie : "—")</span>
            </div>
            <div class="ed-divider"></div>
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-hash"></i> Folio</span>
                <span class="ed-info-value">@(!string.IsNullOrWhiteSpace(Model.Folio) ? Model.Folio : "—")</span>
            </div>
            <div class="ed-divider"></div>
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-patch-check"></i> UUID</span>
                <code class="ec-rfc td-uuid-full" title="@Model.Uuid">@Model.Uuid</code>
            </div>
        </div>

        <!-- Tarjeta 3: Mensaje MF -->
        <div class="errores-ring-card timbrado-cards-row">
            <div class="ed-info-section">
                <span class="ec-label"><i class="bi bi-chat-dots-fill"></i> Mensaje MF</span>
                @if (!string.IsNullOrWhiteSpace(Model.MensajeMf))
                {
                    <div class="td-msg-box td-msg-warn">
                        <i class="bi bi-info-circle-fill td-msg-icon warn"></i>
                        <p>@Model.MensajeMf</p>
                    </div>
                }
                else
                {
                    <div class="td-msg-box td-msg-ok">
                        <i class="bi bi-check-circle-fill td-msg-icon ok"></i>
                        <p>OK — Sin observaciones</p>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ── XML Viewer ── -->
    <div class="ed-json-card">

        <div class="ed-json-header">
            <div>
                <h4 class="ed-json-title">
                    <i class="bi bi-code-slash"></i> XML Timbrado
                </h4>
                <span class="ed-json-sub">Contenido XML completo del CFDI timbrado</span>
            </div>
            <span class="ed-json-badge ed-json-valid">XML</span>
        </div>

        <div class="ed-json-toolbar">
            <button class="ed-tool-btn" onclick="copiarXML()">
                <i class="bi bi-clipboard"></i> Copiar XML
            </button>
            <button class="ed-tool-btn" onclick="descargarXML()">
                <i class="bi bi-download"></i> Descargar
            </button>
            <button class="ed-tool-btn" onclick="formatearXML()">
                <i class="bi bi-arrow-clockwise"></i> Re-formatear
            </button>
            <span class="ed-json-size">
                Tamaño: <strong id="xmlSize">0</strong> caracteres
            </span>
        </div>

        <div class="ed-json-content" id="xmlViewer">
            @if (!string.IsNullOrWhiteSpace(Model.XmlTimbrado))
            {
                <pre id="xmlContent">@Html.Raw(System.Net.WebUtility.HtmlEncode(Model.XmlTimbrado))</pre>
            }
            else
            {
                <div class="ed-json-empty">
                    <i class="bi bi-file-earmark-x ed-empty-icon"></i>
                    <h5>No hay XML disponible</h5>
                    <p>No se encontró contenido XML para este timbrado.</p>
                </div>
            }
        </div>

    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const el = document.getElementById('xmlContent');
            if (!el) return;
            const raw = el.textContent || el.innerText || '';
            renderXmlInViewer(raw);
        });

        function mostrarNotificacion(mensaje, tipo = 'success') {
            const div = document.createElement('div');
            div.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;
                background:${tipo === 'success' ? '#11998e' : '#ff416c'};color:white;
                padding:12px 20px;border-radius:12px;font-size:14px;
                box-shadow:0 8px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:8px;`;
            div.innerHTML = `<i class="bi bi-${tipo === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${mensaje}`;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 3000);
        }

        async function copiarXML() {
            try {
                const response = await fetch('@Url.Action("GetXmlFormatted", "Timbrados")?id=@Model.Id');
                const data = await response.json();
                if (data.success && data.xmlFormatted) {
                    await navigator.clipboard.writeText(data.xmlFormatted);
                    mostrarNotificacion('XML copiado al portapapeles');
                } else {
                    const raw = document.getElementById('xmlContent')?.innerText ?? '';
                    await navigator.clipboard.writeText(raw);
                    mostrarNotificacion('XML copiado (crudo)');
                }
            } catch (error) {
                mostrarNotificacion('Error al copiar: ' + error.message, 'error');
            }
        }

        function descargarXML() {
            const xmlContent = document.getElementById('xmlContent')?.innerText ?? '';
            if (!xmlContent.trim()) {
                mostrarNotificacion('No hay XML para descargar', 'error');
                return;
            }
            const blob = new Blob([xmlContent], { type: 'application/xml' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = "@fileNameXml";
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        async function formatearXML() {
            try {
                const response = await fetch('@Url.Action("GetXmlFormatted", "Timbrados")?id=@Model.Id');
                const data = await response.json();
                if (data.success && data.xmlFormatted) {
                    const viewer = document.getElementById('xmlViewer');
                    viewer.innerHTML = `<pre id="xmlContent"></pre>`;
                    renderXmlInViewer(data.xmlFormatted);
                    mostrarNotificacion('XML formateado correctamente');
                } else {
                    mostrarNotificacion('No se pudo formatear XML', 'error');
                }
            } catch (error) {
                mostrarNotificacion('Error: ' + error.message, 'error');
            }
        }

        function highlightXml(xml) {
            if (!xml) return '';
            xml = xml.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
            xml = xml.replace(/(&lt;!--[\s\S]*?--&gt;)/g, '<span class="xml-comment">$1</span>');
            xml = xml.replace(/(&lt;\/?)([\w:.-]+)([^&]*?)(\/?&gt;)/g,
                function (m, p1, tag, attrs, p4) {
                    attrs = attrs.replace(/([\w:.-]+)=(".*?")/g,
                        '<span class="xml-attr-name">$1</span>=<span class="xml-attr-val">$2</span>');
                    return '<span class="xml-punct">&lt;</span>'
                        + '<span class="xml-tag">' + tag + '</span>'
                        + attrs
                        + '<span class="xml-punct">' + p4.replace('&gt;', '&gt;') + '</span>';
                });
            return xml;
        }

        function renderXmlInViewer(xmlText) {
            const pre = document.getElementById('xmlContent');
            if (!pre) return;
            pre.innerHTML = highlightXml(xmlText);
            const sizeEl = document.getElementById('xmlSize');
            if (sizeEl) sizeEl.textContent = (xmlText?.length || 0).toLocaleString();
        }
    </script>
}
