@model Vigma.TimbradoGateway.ViewModels.Timbrados.TimbradoIndiceVM
@{
    ViewData["Title"] = "Índice de Timbrados";
    Layout = "_Layout";
    var from = Model.TotalRows == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var to = Math.Min(Model.Page * Model.PageSize, Model.TotalRows);
}

<link href="~/css/gstyle.css" rel="stylesheet" />
<link href="~/css/errores.css" rel="stylesheet" />
<link href="~/css/timbrados.css" rel="stylesheet" />

<div class="errores-page">

    <!-- ── Header ── -->
    <div class="errores-header">
        <div class="errores-header-left">
            <span class="tb-badge-top">
                <i class="bi bi-receipt-cutoff"></i> Timbrados
            </span>
            <h1 class="errores-title">Monitor de Timbrados</h1>
            <span class="errores-subtitle">
                Últimos timbrados registrados • Ordenados por <strong>created_utc DESC</strong>
            </span>
        </div>
        <div class="errores-header-right">
            <div class="ec-stat-pill">
                <span class="ec-stat-num">@(Model.Rows?.Count() ?? 0)</span>
                <span class="ec-stat-label">Resultados</span>
            </div>
            <div class="ec-stat-pill tb-stat-cancel">
                <span class="ec-stat-num">@Model.CanceladasCount</span>
                <span class="ec-stat-label">Canceladas</span>
            </div>
        </div>
    </div>

    <!-- ── Filtros ── -->
    <div class="ec-filter-card tb-filter-card">
        <div class="ec-filter-header">
            <i class="bi bi-funnel-fill" style="color:var(--color-warning)"></i>
            <span>Filtros de búsqueda</span>
        </div>

        <form asp-action="Index" asp-controller="Timbrados" method="get">
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />

            <div class="ec-filter-grid">
                <div class="ec-field">
                    <label class="ec-label"><i class="bi bi-people"></i> Tenant</label>
                    @Html.DropDownListFor(m => m.TenantId, Model.Tenants, new { @class = "ec-select" })
                </div>

                <div class="ec-field">
                    <label class="ec-label"><i class="bi bi-building"></i> RFC Emisor</label>
                    @Html.TextBoxFor(m => m.RfcEmisor, new { @class = "ec-input", placeholder = "EKU9003173C9..." })
                </div>

                <div class="ec-field">
                    <label class="ec-label"><i class="bi bi-calendar"></i> Fecha inicio</label>
                    @Html.TextBoxFor(m => m.FechaInicio, "{0:yyyy-MM-dd}", new { @type = "date", @class = "ec-input" })
                </div>

                <div class="ec-field">
                    <label class="ec-label"><i class="bi bi-calendar-check"></i> Fecha final</label>
                    @Html.TextBoxFor(m => m.FechaFinal, "{0:yyyy-MM-dd}", new { @type = "date", @class = "ec-input" })
                </div>

                <div class="ec-field ec-field-actions">
                    <button type="submit" class="vg-btn vg-btn-primary">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                    <a class="vg-btn vg-btn-outline" href="@Url.Action("Index", "Timbrados")">
                        <i class="bi bi-arrow-clockwise"></i> Limpiar
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- ── Tabla ── -->
    <div class="ec-table-card">
        <div class="ec-table-header">
            <div class="ec-table-title">
                <i class="bi bi-table"></i> Registro de timbrados
            </div>
            <span class="ec-table-count">Mostrando @(Model.Rows?.Count() ?? 0) resultados</span>
        </div>

        <div class="ec-table-wrap">
            <table class="ec-table tb-table">
                <thead>
                    <tr>
                        <th style="width:40px;">Tenant</th>
                        <th style="width:150px;">RFC Emisor</th>
                        <th style="width:80px;">Origen</th>
                        <th style="width:40px;">Tipo</th>
                        <th style="width:40px;">Serie</th>
                        <th style="width:40px;">Folio</th>
                        <th style="width:200px;">UUID</th>
                        <th>Mensaje MF</th>
                        <th style="width:90px;">Saldo</th>
                        <th style="width:155px;">Creado (UTC)</th>
                        <th style="width:170px;" class="ec-th-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows == null || !Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="11">
                                <div class="ec-empty">
                                    <i class="bi bi-inbox ec-empty-icon"></i>
                                    <h5>No se encontraron timbrados</h5>
                                    <p>Ajusta los filtros o selecciona otro rango de fechas.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var r in Model.Rows)
                        {
                            <tr class="ec-row @(r.Cancelada ? "tb-row-cancel" : "")">
                                <td><span class="ec-tenant">@r.TenantId</span></td>
                                <td><code class="ec-rfc" title="@r.RfcEmisor">@r.RfcEmisor</code></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(r.Origen))
                                    {
                                        <span class="tb-pill tb-pill-mid">@r.Origen</span>
                                    }
                                    else
                                    {

                                        <span class="ec-na">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(r.TipoDeComprobante))
                                    {
                                        <span class="tb-pill tb-pill-ok">@r.TipoDeComprobante</span>
                                    }
                                    else
                                    {

                                        <span class="ec-na">N/A</span>
                                    }
                                </td>
                                <td><span class="tb-plain">@(string.IsNullOrWhiteSpace(r.Serie) ? "-" : r.Serie)</span></td>
                                <td><span class="tb-plain">@(string.IsNullOrWhiteSpace(r.Folio) ? "-" : r.Folio)</span></td>
                                <td><code class="ec-rfc tb-uuid" title="@r.Uuid">@r.Uuid</code></td>
                                <td>
                                    <div class="ec-message" title="@r.MensajeMf">@r.MensajeMf</div>
                                </td>
                                <td>
                                    @if (r.Saldo.HasValue)
                                    {
                                        <span class="tb-pill tb-pill-mid">@r.Saldo.Value.ToString("N2")</span>
                                    }
                                    else
                                    {

                                        <span class="ec-na">N/A</span>
                                    }
                                </td>
                                <td>
                                    <span class="ec-time">
                                        <i class="bi bi-clock"></i>
                                        @r.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss")
                                    </span>
                                </td>
                                <td class="ec-td-center">
                                    <a class="ec-btn-action"
                                           href="@Url.Action("TimbradosDetalle", "Timbrados", new { id = r.Id })">
                                        <i class="bi bi-eye"></i> Detalle
                                    </a>
                                    <a class="ec-btn-action"
                                           href="@Url.Action("TimbradosAdicionales", "Timbrados", new { id = r.Id })">
                                        <i class="bi bi-plus-circle"></i> Adicionales
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- ── Paginación ── -->
        @if (Model.TotalPages > 1)
        {
            <div class="tb-pagination">
                <span class="tb-page-info">
                    Página <strong>@Model.Page</strong> de <strong>@Model.TotalPages</strong> • @Model.PageSize por página
                </span>

                <div class="tb-page-btns">
                    <a class="tb-page-btn @(!Model.HasPrev ? "tb-page-btn-disabled" : "")"
                           href="@(Model.HasPrev? Url.Action("Index", "Timbrados", new { tenantId = Model.TenantId, rfcEmisor = Model.RfcEmisor, fechaInicio = Model.FechaInicio?.ToString("yyyy-MM-dd"), fechaFinal = Model.FechaFinal?.ToString("yyyy-MM-dd"), page = Model.Page - 1, pageSize = Model.PageSize }) : "#")">
                        «
                    </a>

                    @{
                        var start = Math.Max(1, Model.Page - 3);
                        var end = Math.Min(Model.TotalPages, start + 6);
                        start = Math.Max(1, end - 6);
                    }

                    @for (int p = start; p <= end; p++)
                    {
                        <a class="tb-page-btn @(p == Model.Page ? "tb-page-btn-active" : "")"
                               href="@Url.Action("Index", "Timbrados", new { tenantId = Model.TenantId, rfcEmisor = Model.RfcEmisor, fechaInicio = Model.FechaInicio?.ToString("yyyy-MM-dd"), fechaFinal = Model.FechaFinal?.ToString("yyyy-MM-dd"), page = p, pageSize = Model.PageSize })">
                            @p
                        </a>
                    }

                    <a class="tb-page-btn @(!Model.HasNext ? "tb-page-btn-disabled" : "")"
                           href="@(Model.HasNext? Url.Action("Index", "Timbrados", new { tenantId = Model.TenantId, rfcEmisor = Model.RfcEmisor, fechaInicio = Model.FechaInicio?.ToString("yyyy-MM-dd"), fechaFinal = Model.FechaFinal?.ToString("yyyy-MM-dd"), page = Model.Page + 1, pageSize = Model.PageSize }) : "#")">
                        »
                    </a>
                </div>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        document.querySelectorAll('.ec-row').forEach((row, i) => {
            row.style.opacity = '0';
            row.style.transform = 'translateY(8px)';
            setTimeout(() => {
                row.style.transition = 'all 0.35s ease';
                row.style.opacity = '1';
                row.style.transform = 'translateY(0)';
            }, i * 35);
        });
    </script>
}

