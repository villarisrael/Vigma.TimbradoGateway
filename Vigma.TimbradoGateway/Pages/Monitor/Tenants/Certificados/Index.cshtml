@page "/Monitor/Tenants/{tenantId:int}/Certificados"
@model Vigma.TimbradoGateway.Pages.Monitor.Tenants.Certificados.IndexModel
@{
    ViewData["Title"] = "Certificados";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Certificados - @Model.TenantNombre</h3>
        <a class="btn btn-primary" href="/Monitor/Tenants/@Model.TenantId/Certificados/Create">+ Agregar</a>
    </div>

    <table class="table table-sm table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>RFC</th>
                <th>Activo</th>
                <th>NoCert</th>
                <th>Vigencia fin</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Items)
            {
                <tr>
                    <td>@c.RFC</td>
                    <td>@(c.Activo ? "Sí" : "No")</td>
                    <td>@(c.NoCertificado ?? "—")</td>
                    <td>@(c.VigenciaFin?.ToLocalTime().ToString("yyyy-MM-dd") ?? "—")</td>
                    <td style="white-space:nowrap;">
                        <a class="btn btn-sm btn-outline-dark"
                           href="/Monitor/Tenants/@Model.TenantId/Certificados/Details/@c.Id">Detalles</a>
                        <a class="btn btn-sm btn-outline-primary"
                           href="/Monitor/Tenants/@Model.TenantId/Certificados/Edit/@c.Id">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a class="btn btn-outline-secondary" href="/Monitor/Tenants/Edit/@Model.TenantId">Volver al tenant</a>
</div>
