@model Vigma.TimbradoGateway.ViewModels.Timbrados.TimbradoDetalleVM
@{
    ViewData["Title"] = $"Timbrado #{Model.Id} - Detalle";
    var fileNameXml = $"timbrado_{Model.Id}_{DateTime.Now:yyyyMMdd_HHmmss}.xml";
}

<style>
    :root {
        --ok-gradient: linear-gradient(135deg, #10b981 0%, #06b6d4 100%);
        --gold-gradient: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        --card-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
        --card-hover-shadow: 0 15px 40px rgba(245, 158, 11, 0.15);
        --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
        background: linear-gradient(135deg, #fff7ed 0%, #f8fafc 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .detail-header {
        background: white;
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 25px;
        box-shadow: var(--card-shadow);
        border-left: 5px solid #f59e0b;
        position: relative;
        overflow: hidden;
    }

        .detail-header::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 200px;
            height: 200px;
            background: var(--gold-gradient);
            opacity: 0.06;
            border-radius: 0 20px 0 0;
        }

    .badge-large {
        padding: 8px 20px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1rem;
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.12) 0%, rgba(251, 191, 36, 0.12) 100%);
        color: #b45309;
        border: 2px solid rgba(245, 158, 11, 0.25);
        display: inline-block;
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: var(--card-shadow);
        border: none;
        transition: var(--transition-smooth);
    }

        .info-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--card-hover-shadow);
        }

    .card-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #64748b;
        font-weight: 700;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .card-value {
        font-size: 1.05rem;
        font-weight: 650;
        color: #1f2937;
        word-break: break-all;
    }

    .mono-badge {
        background: rgba(59, 130, 246, 0.10);
        color: #2563eb;
        padding: 6px 16px;
        border-radius: 10px;
        font-family: 'Consolas', monospace;
        font-weight: 650;
        border: 1px solid rgba(59, 130, 246, 0.20);
        display: inline-block;
    }

    .pill {
        padding: 7px 14px;
        border-radius: 999px;
        font-weight: 750;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .pill-ok {
        background: rgba(16, 185, 129, 0.12);
        color: #065f46;
        border-color: rgba(16, 185, 129, 0.22);
    }

    .pill-cancel {
        background: rgba(239, 68, 68, 0.10);
        color: #991b1b;
        border-color: rgba(239, 68, 68, 0.22);
    }

    .pill-mid {
        background: rgba(148, 163, 184, 0.12);
        color: #475569;
        border-color: rgba(148, 163, 184, 0.25);
    }

    .xml-editor-container {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        margin-top: 25px;
    }

    .xml-header {
        background: linear-gradient(135deg, #111827 0%, #334155 100%);
        padding: 20px 25px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .xml-toolbar {
        background: #f8fafc;
        padding: 15px 25px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
    }

    .xml-content {
        min-height: 520px;
        max-height: 760px; 
        overflow-y: auto; 
        overflow-x: auto; 
        padding: 22px;
        background: #0b1220;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 13.5px;
        line-height: 1.55;
        color: #e5e7eb;
        scrollbar-gutter: stable;
    }


    .btn-icon {
        padding: 8px 16px;
        border-radius: 10px;
        font-weight: 650;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition-smooth);
        border: 1px solid #e2e8f0;
        background: white;
        color: #475569;
    }

        .btn-icon:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        }

        .btn-icon.btn-copy:hover {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

        .btn-icon.btn-download:hover {
            background: #10b981;
            color: white;
            border-color: #10b981;
        }

        .btn-icon.btn-reload:hover {
            background: #f59e0b;
            color: white;
            border-color: #f59e0b;
        }

    .copy-success {
        position: fixed;
        top: 20px;
        right: 20px;
        background: #10b981;
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.30);
        z-index: 1000;
        animation: slideIn 0.3s ease, fadeOut 0.3s ease 2.7s forwards;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes fadeOut {
        from {
            opacity: 1;
        }

        to {
            opacity: 0;
        }
    }

    .time-badge {
        background: #f8fafc;
        padding: 8px 16px;
        border-radius: 10px;
        font-family: 'Consolas', monospace;
        color: #475569;
        border: 1px solid #e2e8f0;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .empty-xml {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        color: #94a3b8;
        text-align: center;
    }

    .empty-xml-icon {
        font-size: 4rem;
        opacity: 0.35;
        margin-bottom: 16px;
    }

    .modal textarea {
        font-family: 'Consolas', monospace;
        font-size: 13px;
        min-height: 55vh;
        border-radius: 12px;
    }
</style>

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="detail-header">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge-large mb-3">
                    <i class="bi bi-receipt-cutoff me-2"></i>Timbrado
                </span>

                <h1 class="display-6 fw-bold mb-2">Detalle del Timbrado #@Model.Id</h1>

                <div class="d-flex flex-wrap gap-3 align-items-center mt-2">
                    <span class="time-badge">
                        <i class="bi bi-clock"></i>
                        @Model.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC
                    </span>

                    <a href="@Url.Action("Index", "Timbrados")" class="btn-icon">
                        <i class="bi bi-arrow-left"></i> Volver al índice
                    </a>

                    @if (Model.Cancelada)
                    {
                        <span class="pill pill-cancel"><i class="bi bi-x-circle-fill"></i> Cancelada</span>
                    }
                    else
                    {
                        <span class="pill pill-ok"><i class="bi bi-check-circle-fill"></i> Vigente</span>
                    }
                </div>
            </div>

            <div class="col-md-4 text-end">
                <div class="d-inline-flex flex-column gap-2 align-items-end">
                    <span class="pill pill-mid">
                        <i class="bi bi-people"></i> Tenant: @Model.TenantId
                    </span>

                    @if (Model.Saldo.HasValue)
                    {
                        <span class="pill pill-mid">
                            <i class="bi bi-cash-coin"></i> Saldo: @Model.Saldo.Value.ToString("N2")
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Info -->
    <div class="row">
        <div class="col-md-4">
            <div class="info-card">
                <div class="card-title"><i class="bi bi-building"></i> RFC Emisor</div>
                <div class="card-value mb-3">
                    <span class="mono-badge">@Model.RfcEmisor</span>
                </div>

                <div class="card-title"><i class="bi bi-box-arrow-in-right"></i> Origen</div>
                <div class="card-value mb-3">@(!string.IsNullOrWhiteSpace(Model.Origen) ? Model.Origen : "—")</div>

                <div class="card-title"><i class="bi bi-file-earmark-text"></i> Tipo de comprobante</div>
                <div class="card-value">
                    @if (!string.IsNullOrWhiteSpace(Model.TipoDeComprobante))
                    {
                        <span class="pill pill-ok"><i class="bi bi-file-earmark-check"></i>@Model.TipoDeComprobante</span>
                    }
                    else
                    {
                        <span class="pill pill-mid"><i class="bi bi-dash-circle"></i> N/A</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="info-card h-100">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card-title"><i class="bi bi-collection"></i> Serie</div>
                        <div class="card-value">@(!string.IsNullOrWhiteSpace(Model.Serie) ? Model.Serie : "—")</div>
                    </div>

                    <div class="col-md-4">
                        <div class="card-title"><i class="bi bi-hash"></i> Folio</div>
                        <div class="card-value">@(!string.IsNullOrWhiteSpace(Model.Folio) ? Model.Folio : "—")</div>
                    </div>

                    <div class="col-md-4">
                        <div class="card-title"><i class="bi bi-patch-check"></i> UUID</div>
                        <div class="card-value">
                            <span class="mono-badge">@Model.Uuid</span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card-title"><i class="bi bi-chat-dots-fill"></i> Mensaje MF</div>
                        <div class="card-value">
                            @if (!string.IsNullOrWhiteSpace(Model.MensajeMf))
                            {
                                <div class="alert alert-warning bg-opacity-10 border-warning" style="border-radius: 12px;">
                                    <div class="d-flex">
                                        <i class="bi bi-info-circle-fill text-warning me-3 fs-5"></i>
                                        <div>@Model.MensajeMf</div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted fst-italic">No hay mensaje del PAC disponible</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- XML Viewer -->
    <div class="xml-editor-container">
        <div class="xml-header">
            <div>
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-code-slash me-2"></i> XML Timbrado
                </h5>
                <small class="opacity-75">Contenido XML completo del CFDI timbrado</small>
            </div>
            <div class="badge bg-success">
                XML
            </div>
        </div>

        <div class="xml-toolbar">
            <button class="btn-icon btn-copy" onclick="copiarXML()">
                <i class="bi bi-clipboard"></i> Copiar XML
            </button>
            <button class="btn-icon btn-download" onclick="descargarXML()">
                <i class="bi bi-download"></i> Descargar
            </button>
            <button class="btn-icon btn-reload" onclick="formatearXML()">
                <i class="bi bi-arrow-clockwise"></i> Re-formatear
            </button>
            <button class="btn-icon" onclick="alternarXML()">
                <i class="bi bi-eye"></i> Alternar vista
            </button>
            <div class="ms-auto">
                <span class="text-muted small">
                    Tamaño: <span id="xmlSize">0</span> caracteres
                </span>
            </div>
        </div>

        <div class="xml-content" id="xmlViewer">
            @if (!string.IsNullOrWhiteSpace(Model.XmlTimbrado))
            {
                <pre id="xmlContent">@Model.XmlTimbrado</pre>
            }
            else
            {
                <div class="empty-xml">
                    <i class="bi bi-file-earmark-x empty-xml-icon"></i>
                    <h5 class="fw-bold mb-2 text-white">No hay XML disponible</h5>
                    <p class="mb-0">No se encontró contenido XML para este timbrado.</p>
                </div>
            }
        </div>
    </div>

</div>


<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Bootstrap JS para modal -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const el = document.getElementById('xmlContent');
        if (el) {
            const text = el.textContent || el.innerText || '';
            document.getElementById('xmlSize').textContent = (text.length || 0).toLocaleString();
        }
    });

    function mostrarNotificacion(mensaje, tipo = 'success') {
        const div = document.createElement('div');
        div.className = 'copy-success';
        div.style.background = (tipo === 'success') ? '#10b981' : '#ef4444';
        div.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="bi bi-${tipo === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                    <span>${mensaje}</span>
                </div>`;
        document.body.appendChild(div);
        setTimeout(() => div.remove(), 3000);
    }

    async function copiarXML() {
        try {
            const response = await fetch('@Url.Action("GetXmlFormatted", "Timbrados")?id=@Model.Id');
            const data = await response.json();

            if (data.success && data.xmlFormatted) {
                await navigator.clipboard.writeText(data.xmlFormatted);
                mostrarNotificacion('XML copiado al portapapeles');
            } else {
                // fallback: copia el crudo
                const raw = document.getElementById('xmlContent')?.innerText ?? '';
                await navigator.clipboard.writeText(raw);
                mostrarNotificacion('XML copiado (crudo)');
            }
        } catch (error) {
            mostrarNotificacion('Error al copiar: ' + error.message, 'error');
        }
    }

    function descargarXML() {
        const xmlContent = document.getElementById('xmlContent')?.innerText ?? '';
        if (!xmlContent.trim()) {
            mostrarNotificacion('No hay XML para descargar', 'error');
            return;
        }
        const blob = new Blob([xmlContent], { type: 'application/xml' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = "@fileNameXml";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    async function formatearXML() {
        try {
            const response = await fetch('@Url.Action("GetXmlFormatted", "Timbrados")?id=@Model.Id');
            const data = await response.json();

            if (data.success && data.xmlFormatted) {
                const viewer = document.getElementById('xmlViewer');
                viewer.innerHTML = `<pre id="xmlContent">${escapeHtml(data.xmlFormatted)}</pre>`;
                document.getElementById('xmlSize').textContent = data.xmlFormatted.length.toLocaleString();
                mostrarNotificacion('XML formateado correctamente');
            } else {
                mostrarNotificacion('No se pudo formatear XML', 'error');
            }
        } catch (error) {
            mostrarNotificacion('Error: ' + error.message, 'error');
        }
    }

    function alternarXML() {
        const modal = new bootstrap.Modal(document.getElementById('rawXmlModal'));
        const textarea = document.getElementById('rawXmlTextarea');
        textarea.value = document.getElementById('xmlContent')?.innerText ?? '';
        modal.show();
    }

    async function copiarTextoCrudo() {
        try {
            const textarea = document.getElementById('rawXmlTextarea');
            await navigator.clipboard.writeText(textarea.value);
            mostrarNotificacion('Texto copiado al portapapeles');
        } catch (e) {
            mostrarNotificacion('No se pudo copiar', 'error');
        }
    }

    function escapeHtml(str) {
        return (str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
    }

    async function verComoJson() {
        try {
            const resp = await fetch('@Url.Action("GetXmlAsJson", "Timbrados")?id=@Model.Id');
            const data = await resp.json();

            if (!data.success) {
                mostrarNotificacion(data.error || 'No se pudo convertir a JSON', 'error');
                return;
            }

            document.getElementById('jsonModalContent').textContent = data.jsonFormatted || '';
            const modal = new bootstrap.Modal(document.getElementById('jsonModal'));
            modal.show();
        } catch (e) {
            mostrarNotificacion('Error: ' + e.message, 'error');
        }
    }

    async function copiarJsonModal() {
        try {
            const txt = document.getElementById('jsonModalContent')?.textContent ?? '';
            await navigator.clipboard.writeText(txt);
            mostrarNotificacion('JSON copiado al portapapeles');
        } catch (e) {
            mostrarNotificacion('No se pudo copiar', 'error');
        }
    }

</script>
